<%- include('partials/admin-header', { title: t.adminOrders.title, page: 'orders' }) %>

<style>
    /* ===== Search Bar ===== */
    .toolbar { margin-bottom: 15px; }
    .search-bar {
        display: flex; align-items: center; background: var(--surface-dark);
        border: 1px solid var(--glass-border); border-radius: 10px;
        padding: 10px 16px; gap: 12px; max-width: 450px;
        transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    }
    .search-bar:focus-within { border-color: var(--primary); box-shadow: 0 0 0 4px rgba(59,130,246,0.15); }
    .search-bar i { color: var(--text-muted); font-size: 1.2rem; }
    .search-bar:focus-within i { color: var(--primary); }
    .search-bar input {
        border: none; background: transparent; color: var(--text-main);
        outline: none; width: 100%; font-size: 0.95rem; font-family: inherit;
    }
    .search-bar input::placeholder { color: var(--text-muted); }

    /* ===== Filter Tabs – ChatGPT‑style underline ===== */
    .filter-tabs {
        display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 1.25rem;
        border-bottom: 1px solid var(--glass-border); padding-bottom: 0;
    }
    .filter-btn {
        position: relative; padding: 10px 20px; border: none; background: transparent;
        color: var(--text-muted); font-weight: 500; font-size: 0.9rem; cursor: pointer;
        transition: color var(--transition-fast), box-shadow var(--transition-fast);
        font-family: inherit; line-height: 1.4; white-space: nowrap;
    }
    .filter-btn::after {
        content: ''; position: absolute; bottom: -1px; left: 0; right: 0; height: 3px;
        background: transparent; border-radius: 3px 3px 0 0; transition: background var(--transition-fast);
    }
    .filter-btn.active { color: var(--primary); font-weight: 600; }
    .filter-btn.active::after { background: var(--primary); }
    .filter-btn:hover:not(.active) { color: var(--text-main); background: rgba(255,255,255,0.03); }
    [data-theme='light'] .filter-btn:hover:not(.active) { background: rgba(0,0,0,0.03); }

    /* ===== Unified Card Grid ===== */
    .orders-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 12px; }
    .order-card {
        background: var(--surface-dark); border: 1px solid var(--glass-border);
        border-radius: 12px; padding: 14px; display: flex; flex-direction: column; gap: 10px;
        box-shadow: var(--shadow-sm); transition: box-shadow var(--transition-fast), transform var(--transition-fast), border-color var(--transition-fast);
    }
    .order-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
    .order-card.highlight { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(59,130,246,0.2); }

    .order-card-top { display: flex; justify-content: space-between; align-items: flex-start; }
    .order-card-medicine { font-weight: 600; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 180px; }
    .order-card-total { font-weight: 700; color: var(--text-main); white-space: nowrap; }

    .order-card-middle { display: flex; justify-content: space-between; align-items: center; color: var(--text-muted); font-size: 0.85rem; }
    .order-card-pharmacy { display: flex; align-items: center; gap: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 130px; }

    .order-card-actions { display: flex; justify-content: space-between; align-items: center; gap: 8px; }
    .eye-btn, .action-btn {
        width: 36px; height: 36px; border-radius: 8px; border: 1px solid var(--glass-border);
        background: transparent; display: flex; align-items: center; justify-content: center;
        cursor: pointer; transition: all var(--transition-fast);
    }
    .eye-btn { color: var(--text-muted); }
    .eye-btn:hover { color: var(--primary); background: rgba(59,130,246,0.1); border-color: var(--primary); }
    .action-btn.approve { color: var(--success); border-color: var(--success); }
    .action-btn.approve:hover { background: var(--success); color: white; }
    .action-btn.cancel { color: var(--danger); border-color: var(--danger); }
    .action-btn.cancel:hover { background: var(--danger); color: white; }
    .delete-order-btn {
        background: transparent; border: 1px solid var(--danger); color: var(--danger);
        padding: 6px 14px; border-radius: 8px; cursor: pointer; font-weight: 600;
        font-size: 0.85rem; display: flex; align-items: center; gap: 6px; transition: all var(--transition-fast);
    }
    .delete-order-btn:hover { background: var(--danger); color: white; }

    /* ===== Order Detail Modal ===== */
    #orderDetailModal .detail-grid {
        display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
        font-size: 0.9rem; margin-bottom: 1rem;
    }
    @media (max-width: 480px) {
        #orderDetailModal .detail-grid { grid-template-columns: 1fr; }
    }
    #orderDetailModal .detail-grid p { margin: 0; color: var(--text-main); }
    #orderDetailModal .detail-grid strong {
        display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 2px;
    }

    /* Modal action buttons */
    .modal-delete-btn {
        background: transparent; border: 1px solid var(--danger); color: var(--danger);
        padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: 600;
        font-size: 0.9rem; display: inline-flex; align-items: center; gap: 8px;
        transition: all var(--transition-fast);
    }
    .modal-delete-btn:hover { background: var(--danger); color: white; }
</style>

<div class="toolbar">
    <div class="search-bar">
        <i class="ph ph-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="<%= t.common.search || 'Search' %>...">
    </div>
</div>

<div class="filter-tabs" id="filterTabs">
    <button class="filter-btn active" data-filter="all"><%= t.adminOrders.filterAll %></button>
    <button class="filter-btn" data-filter="pending"><%= t.adminDashboard.pending %></button>
    <button class="filter-btn" data-filter="approved"><%= t.adminDashboard.approved %></button>
    <button class="filter-btn" data-filter="cancelled"><%= t.adminDashboard.cancelled %></button>
</div>

<section class="card" style="margin: 0;">
    <div class="orders-grid" id="ordersGrid">
        <% if (orders && orders.length > 0) { %>
            <% orders.forEach((order) => { %>
            <div class="order-card order-row" 
                 data-status="<%= order.status.toLowerCase() %>" 
                 id="order-<%= order._id %>"
                 data-search-text="<%= (order.medicineId?.name || '').toLowerCase() %> <%= (order.user?.name || '').toLowerCase() %> <%= order.status.toLowerCase() %> <%= order.totalPrice %>">
                <div class="order-card-top">
                    <span class="order-card-medicine"><%= order.medicineId ? order.medicineId.name : t.adminOrders.deletedMedicine %></span>
                    <span class="order-card-total">$<%= order.totalPrice || '0.00' %></span>
                </div>
                <div class="order-card-middle">
                    <span class="order-card-pharmacy">
                        <i class="ph ph-storefront"></i>
                        <%= order.user?.name || t.adminOrders.unknownUser %>
                    </span>
                    <span class="badge <%= order.status.toLowerCase() %>" id="badge-<%= order._id %>">
    <%= order.status.toLowerCase() === 'approved' ? t.adminDashboard.approved : (order.status.toLowerCase() === 'cancelled' ? t.adminDashboard.cancelled : t.adminDashboard.pending) %>
</span>
                </div>
                <div class="order-card-actions">
                    <button class="eye-btn" 
                            data-order="<%= encodeURIComponent(JSON.stringify(order)) %>"
                            onclick="openOrderDetail(this)" 
                            title="<%= t.common.viewDetails || 'View Details' %>">
                        <i class="ph ph-eye"></i>
                    </button>
                    <% if(order.status === 'Pending' || order.status === 'pending') { %>
                        <div class="actions" id="actions-<%= order._id %>" style="display: flex; gap: 8px;">
                            <button class="action-btn approve status-btn" title="<%= t.adminDashboard.approved || 'Approve' %>" data-id="<%= order._id %>" data-status="approved">
                                <i class="ph ph-check"></i>
                            </button>
                            <button class="action-btn cancel status-btn" title="<%= t.common.cancel || 'Cancel' %>" data-id="<%= order._id %>" data-status="cancelled">
                                <i class="ph ph-x"></i>
                            </button>
                        </div>
                    <% } else { %>
                        <button class="delete-order-btn" data-id="<%= order._id %>" title="<%= t.common.delete || 'Delete' %>">
                            <i class="ph ph-trash"></i> <%= t.common.delete || 'Delete' %>
                        </button>
                    <% } %>
                </div>
            </div>
            <% }) %>
        <% } else { %>
            <div class="empty-state" style="grid-column: 1 / -1;">
                <i class="ph ph-package"></i>
                <p><%= t.adminOrders.noOrders %></p>
            </div>
        <% } %>
    </div>
</section>

<div id="toast-container"></div>

<div id="confirmModal" class="custom-backdrop" style="display: none;">
    <div class="modal-content confirmation-box" style="opacity: 0;">
        <div class="icon-box danger large">
            <i class="ph ph-trash"></i>
        </div>
        <h3><%= t.common.delete %>?</h3>
        <p><%= t.adminOrders.deleteConfirmMessage || "Are you sure you want to delete this order?" %></p>
        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeModal()"><%= t.common.cancel %></button>
            <button class="btn-delete" id="confirmDeleteBtn"><%= t.common.delete %></button>
        </div>
    </div>
</div>

<div id="orderDetailModal" class="custom-backdrop" style="display: none;">
    <div class="modal-content" style="max-width: 480px; width: 95%; opacity: 0;">
        <div class="card-header" style="margin-bottom: 1rem;">
            <h3 style="margin:0;"><%= t.common.viewDetails || 'Order Details' %></h3>
        </div>
        <div id="orderDetailContent"></div>
        <div class="modal-actions" id="modalActionsContainer" style="margin-top: 1.5rem;"></div>
    </div>
</div>

<script>
    (function() {
        const confirmModal = document.getElementById('confirmModal');
        const detailModal = document.getElementById('orderDetailModal');
        const toastContainer = document.getElementById('toast-container');
        document.body.appendChild(confirmModal);
        document.body.appendChild(detailModal);
        document.body.appendChild(toastContainer);

        let currentOrderId = null;

        function showToast(msg, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            toast.innerHTML = `<i class="ph ph-${type === 'success' ? 'check-circle' : 'warning-circle'}"></i> <span>${msg}</span>`;
            toastContainer.appendChild(toast);
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(-20px)';
                setTimeout(() => toast.remove(), 300);
            }, 3000);
        }

        // ========== SEARCH + FILTER ==========
        const searchInput = document.getElementById('searchInput');
        const filterBtns = document.querySelectorAll('#filterTabs .filter-btn');
        const orderCards = document.querySelectorAll('.order-card');
        let currentFilter = 'all';

        function applyFilters() {
            const searchTerm = searchInput.value.toLowerCase().trim();
            orderCards.forEach(card => {
                const cardStatus = card.dataset.status;
                const matchesFilter = currentFilter === 'all' || cardStatus === currentFilter;
                const matchesSearch = !searchTerm || card.dataset.searchText.includes(searchTerm);
                const isVisible = matchesFilter && matchesSearch;
            
                card.style.display = isVisible ? '' : 'none';
                if (isVisible && searchTerm) card.classList.add('highlight');
                else card.classList.remove('highlight');
            });
        }

        searchInput.addEventListener('input', applyFilters);
        filterBtns.forEach(btn => {
            btn.addEventListener('click', function() {
                filterBtns.forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                currentFilter = this.dataset.filter;
                applyFilters();
            });
        });

        // ========== Status Update (Approve/Cancel) ==========
        function attachStatusListeners() {
            document.querySelectorAll('.status-btn, .modal-approve-btn, .modal-cancel-btn').forEach(btn => {
                btn.removeEventListener('click', statusHandler);
                btn.addEventListener('click', statusHandler);
            });
        }

        async function statusHandler() {
            const id = this.dataset.id;
            const newStatus = this.dataset.status;
            const originalHTML = this.innerHTML;
            this.innerHTML = '<i class="ph ph-spinner ph-spin"></i>';
            this.disabled = true;

            try {
                const res = await fetch(`/admin/orders/${id}/status`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: newStatus })
                });
                if (res.ok) {
                    showToast(`<%= t.common.success || 'Success' %>`, 'success');
                    const badge = document.getElementById(`badge-${id}`);
                    if (badge) { badge.className = `badge ${newStatus.toLowerCase()}`; badge.innerText = newStatus; }
                    const actionsDiv = document.getElementById(`actions-${id}`);
                    if (actionsDiv) {
                        actionsDiv.innerHTML = `<button class="delete-order-btn" data-id="${id}"><i class="ph ph-trash"></i> <%= t.common.delete || 'Delete' %></button>`;
                        attachDeleteListeners();
                    }
                    const card = document.getElementById(`order-${id}`);
                    if (card) {
                        card.dataset.status = newStatus.toLowerCase();
                        const oldText = card.dataset.searchText;
                        card.dataset.searchText = oldText.replace(/(pending|approved|cancelled)/i, newStatus.toLowerCase());
                    }
                    closeDetailModal();
                } else {
                    showToast(`<%= t.common.error || 'Update failed' %>`, 'error');
                    this.innerHTML = originalHTML;
                    this.disabled = false;
                }
            } catch (err) {
                showToast(`<%= t.common.error || 'Network error' %>`, 'error');
                this.innerHTML = originalHTML;
                this.disabled = false;
            }
        }
        attachStatusListeners();

        // ========== Delete Modal ==========
        let orderIdToDelete = null;

        function openDeleteModal(id) {
            orderIdToDelete = id;
            confirmModal.style.display = 'flex';
            const inner = confirmModal.querySelector('.modal-content');
            inner.style.display = 'block';
            inner.style.opacity = '1';
        }

        window.closeModal = function() {
            orderIdToDelete = null;
            confirmModal.style.display = 'none';
            const inner = confirmModal.querySelector('.modal-content');
            inner.style.display = 'none';
            inner.style.opacity = '0';
        };

        confirmModal.addEventListener('click', (e) => { if (e.target === confirmModal) closeModal(); });

        function attachDeleteListeners() {
            document.querySelectorAll('.delete-order-btn').forEach(btn => {
                btn.removeEventListener('click', deleteClickHandler);
                btn.addEventListener('click', deleteClickHandler);
            });
        }
        function deleteClickHandler() { openDeleteModal(this.dataset.id); }
        attachDeleteListeners();

        document.getElementById('confirmDeleteBtn').addEventListener('click', async function() {
            if (!orderIdToDelete) return;
            const originalText = this.innerText;
            this.innerText = '...';
            this.disabled = true;
            try {
                const res = await fetch(`/admin/orders/${orderIdToDelete}`, { method: 'DELETE' });
                if (res.ok) {
                    const card = document.getElementById(`order-${orderIdToDelete}`);
                    if (card) card.style.display = 'none';
                    showToast(`<%= t.common.success || 'Order deleted' %>`, 'success');
                } else {
                    showToast(`<%= t.common.error || 'Failed to delete' %>`, 'error');
                }
            } catch (err) {
                showToast(`<%= t.common.error || 'Network error' %>`, 'error');
            } finally {
                closeModal();
                this.innerText = originalText;
                this.disabled = false;
            }
        });

        // ========== Order Detail Modal ==========
        window.openOrderDetail = function(btn) {
            try {
                const encodedData = btn.getAttribute('data-order');
                const order = JSON.parse(decodeURIComponent(encodedData));
                currentOrderId = order._id;

                const medName = order.medicineId ? order.medicineId.name : '<%= t.adminOrders.deletedMedicine %>';
                const pharmacy = order.user?.name || '<%= t.adminOrders.unknownUser %>';
                const dateStr = order.createdAt ? new Date(order.createdAt).toLocaleDateString() : 'N/A';

                document.getElementById('orderDetailContent').innerHTML = `
                    <div class="detail-grid">
                        <p><strong><%= t.common.medicines || 'Medicine' %></strong> ${medName}</p>
                        <p><strong><%= t.common.pharmacy || 'Pharmacy' %></strong> ${pharmacy}</p>
                        <p><strong><%= t.common.quantity || 'Quantity' %></strong> ${order.quantity}</p>
                        <p><strong><%= t.common.total || 'Total' %></strong> $${order.totalPrice || '0.00'}</p>
                        <p><strong><%= t.common.date || 'Date' %></strong> ${dateStr}</p>
                        <p><strong><%= t.common.status || 'Status' %></strong> <span class="badge ${order.status.toLowerCase()}">${order.status}</span></p>
                    </div>
                `;

                const actionsContainer = document.getElementById('modalActionsContainer');
                if (order.status === 'Pending' || order.status === 'pending') {
                    actionsContainer.innerHTML = `
                        <button class="btn-primary modal-approve-btn" style="flex:1" data-id="${order._id}" data-status="approved">
                            <i class="ph ph-check"></i> <%= t.adminDashboard.approved || 'Approve' %>
                        </button>
                        <button class="btn-delete modal-cancel-btn" style="flex:1; background: var(--danger)" data-id="${order._id}" data-status="cancelled">
                            <i class="ph ph-x"></i> <%= t.common.cancel || 'Cancel' %>
                        </button>
                    `;
                    attachStatusListeners();
                } else {
                    actionsContainer.innerHTML = `
                        <button class="modal-delete-btn" onclick="openDeleteModal('${order._id}'); closeDetailModal();" style="margin-right: auto;">
                            <i class="ph ph-trash"></i> <%= t.common.delete || 'Delete' %>
                        </button>
                        <button class="btn-cancel" onclick="closeDetailModal()"><%= t.common.cancel || 'Close' %></button>
                    `;
                }

                detailModal.style.display = 'flex';
                const innerBox = detailModal.querySelector('.modal-content');
                innerBox.style.display = 'block';
                innerBox.style.opacity = '1';
            } catch(e) {
                console.error("Failed to parse order data", e);
            }
        };

        window.closeDetailModal = function() {
            detailModal.style.display = 'none';
            const innerBox = detailModal.querySelector('.modal-content');
            innerBox.style.display = 'none';
            innerBox.style.opacity = '0';
        };

        detailModal.addEventListener('click', (e) => { if (e.target === detailModal) closeDetailModal(); });
    })();
</script>

<%- include('partials/admin-footer', { page: 'orders' }) %>