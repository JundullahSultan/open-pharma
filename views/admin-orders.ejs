<%- include('partials/admin-header', { title: t.adminOrders.title, page: 'orders' }) %>

<style>
    /* ===== LAYOUT & TOOLBAR ===== */
    .toolbar { 
        margin-bottom: 16px; 
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    @media (min-width: 768px) {
        .toolbar { flex-direction: row; justify-content: space-between; align-items: center; }
    }

    .search-bar {
        display: flex;
        align-items: center;
        background: var(--surface-dark);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 8px 14px;
        gap: 10px;
        transition: all 0.2s ease;
        max-width: 400px;
        width: 100%;
        box-shadow: var(--shadow-sm);
    }
    .search-bar:focus-within {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
    }
    .search-bar i { color: var(--text-muted); font-size: 1.1rem; }
    .search-bar:focus-within i { color: var(--primary); }
    .search-bar input {
        border: none; background: transparent; color: var(--text-main);
        outline: none; width: 100%; font-size: 0.9rem; font-family: inherit;
    }
    .search-bar input::placeholder { color: var(--text-muted); }

    /* ===== MODERN TAB BAR ===== */
    .filter-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        background: rgba(0, 0, 0, 0.15);
        padding: 4px;
        border-radius: 10px;
        border: 1px solid var(--glass-border);
        width: fit-content;
    }
    .tab-btn {
        background: transparent;
        border: none;
        color: var(--text-muted);
        padding: 6px 14px;
        font-size: 0.85rem;
        font-weight: 600;
        cursor: pointer;
        border-radius: 6px;
        transition: all 0.2s ease;
        text-transform: capitalize;
    }
    .tab-btn:hover {
        color: var(--text-main);
        background: rgba(255, 255, 255, 0.03);
    }
    .tab-btn.active {
        background: var(--primary);
        color: white;
        box-shadow: var(--shadow-sm);
    }

    /* ===== ULTRA DENSE ROWS ===== */
    .orders-list-header {
        display: grid;
        grid-template-columns: 1.2fr 2fr 2fr 1.2fr 1.2fr 120px;
        gap: 12px;
        padding: 0 16px 8px 16px;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
        border-bottom: 1px solid var(--glass-border);
        margin-bottom: 8px;
    }

    .order-list-row {
        display: grid;
        grid-template-columns: 1.2fr 2fr 2fr 1.2fr 1.2fr 120px;
        gap: 12px;
        align-items: center;
        padding: 10px 16px;
        background: linear-gradient(145deg, var(--surface-dark) 0%, rgba(255,255,255,0.01) 100%);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        margin-bottom: 6px;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: var(--shadow-sm);
    }
    .order-list-row:hover {
        border-color: rgba(59, 130, 246, 0.4);
        box-shadow: var(--shadow-md);
        transform: translateX(4px);
    }

    .order-ref { font-family: monospace; font-size: 0.85rem; color: var(--text-muted); font-weight: 600; }
    .order-med { font-weight: 600; color: var(--text-main); font-size: 0.9rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .order-pharmacy { font-size: 0.85rem; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .order-price { font-weight: 700; color: var(--primary); font-size: 0.9rem; }

    /* Compact Pill Badges */
    .badge {
        padding: 2px 8px;
        font-size: 0.65rem;
        border-radius: 20px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-block;
        width: fit-content;
    }
    .badge.pending { background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(245,158,11,0.2); }
    .badge.approved { background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(16,185,129,0.2); }
    .badge.cancelled { background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.2); }

    /* Action Icon Buttons */
    .order-actions-cell {
        display: flex;
        gap: 6px;
        justify-content: flex-end;
        align-items: center;
    }
    .action-btn-sm {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1px solid var(--glass-border);
        background: var(--surface-light);
        color: var(--text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 1rem;
    }
    .action-btn-sm:hover { color: var(--primary); background: rgba(59, 130, 246, 0.15); border-color: var(--primary); }
    .action-btn-sm.approve:hover { color: var(--success); background: rgba(16, 185, 129, 0.15); border-color: var(--success); }
    .action-btn-sm.cancel:hover { color: var(--danger); background: rgba(239, 68, 68, 0.15); border-color: var(--danger); }

    /* Responsive Grid Fallback for Mobile Screen Sizes */
    @media (max-width: 768px) {
        .orders-list-header { display: none; }
        .order-list-row {
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            padding: 12px;
        }
        .order-med, .order-pharmacy { grid-column: span 2; white-space: normal; }
        .order-actions-cell { grid-column: span 2; justify-content: flex-start; margin-top: 4px; border-top: 1px dashed var(--glass-border); padding-top: 8px; }
    }

    /* ===== PREMIUM DETAILS MODAL OVERLAYS ===== */
    .custom-backdrop {
        display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        background: rgba(0,0,0,0.6); backdrop-filter: blur(6px); z-index: 9999;
        align-items: center; justify-content: center;
    }
    .modal-content-animated {
        background: var(--surface-dark); border: 1px solid var(--glass-border);
        border-radius: 20px; padding: 24px; width: 95%; max-width: 500px;
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
        animation: slideUpFade 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    @keyframes slideUpFade {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .modal-info-group {
        display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin-bottom: 20px;
    }
    @media (max-width: 480px) { .modal-info-group { grid-template-columns: 1fr; } }
    
    .info-item {
        display: flex; align-items: center; gap: 12px; background: var(--bg-dark);
        padding: 12px 16px; border-radius: 12px; border: 1px solid var(--glass-border);
    }
    .info-icon {
        width: 38px; height: 38px; border-radius: 10px; background: rgba(59, 130, 246, 0.1);
        color: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 1.25rem; flex-shrink: 0;
    }
    .info-text { display: flex; flex-direction: column; gap: 2px; overflow: hidden; }
    .info-label { font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; }
    .info-value { font-size: 0.95rem; color: var(--text-main); font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    .modal-total-row {
        display: flex; justify-content: space-between; align-items: center;
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(59, 130, 246, 0.02));
        border: 1px solid rgba(59, 130, 246, 0.2); padding: 20px; border-radius: 14px; margin-bottom: 16px;
    }
    .total-amount { font-size: 1.8rem; font-weight: 800; color: var(--primary); line-height: 1; }

    .modal-notes {
        background: rgba(245, 158, 11, 0.05); border: 1px dashed rgba(245, 158, 11, 0.3);
        padding: 16px; border-radius: 12px; margin-bottom: 20px;
    }
    .notes-header { display: flex; align-items: center; gap: 8px; color: var(--warning); font-size: 0.85rem; font-weight: 700; text-transform: uppercase; }
    
    .modal-footer-actions { display: flex; justify-content: flex-end; gap: 10px; border-top: 1px solid var(--glass-border); padding-top: 16px; }
    .btn-outline { background: transparent; border: 1px solid var(--glass-border); color: var(--text-main); padding: 8px 16px; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 0.9rem; }
    .btn-outline:hover { background: var(--surface-light); }
    .btn-danger-sm { background: var(--danger); color: white; border: none; padding: 8px 16px; border-radius: 8px; cursor: pointer; font-weight: 600; font-size: 0.9rem; }
    .btn-danger-sm:hover { background: #dc2626; }
</style>

<div id="toast-container"></div>

<div class="toolbar">
    <div class="search-bar">
        <i class="ph ph-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="<%= t.adminOrders.searchPlaceholder %>" onkeyup="filterOrders()">
    </div>

    <div class="filter-tabs">
        <button class="tab-btn active" onclick="filterTab('all', this)"><%= t.adminOrders.all || 'All' %></button>
        <button class="tab-btn" onclick="filterTab('pending', this)"><%= t.adminOrders.pending || 'Pending' %></button>
        <button class="tab-btn" onclick="filterTab('approved', this)"><%= t.adminOrders.approved || 'Approved' %></button>
        <button class="tab-btn" onclick="filterTab('cancelled', this)"><%= t.adminOrders.cancelled || 'Cancelled' %></button>
    </div>
</div>

<div class="orders-list-container">
    <div class="orders-list-header">
        <div>Ref ID</div>
        <div>Medicine</div>
        <div>Pharmacy</div>
        <div>Total Price</div>
        <div>Status</div>
        <div style="text-align: right;">Actions</div>
    </div>

    <div id="ordersGrid">
        <% orders.forEach(order => { 
            const stringId = order._id.toString();
        %>
            <div class="order-list-row" id="row-<%= order._id %>" data-status="<%= order.status.toLowerCase() %>" data-med="<%= order.medicineId ? order.medicineId.name.toLowerCase() : '' %>" data-pharmacy="<%= order.user ? (order.user.pharmacy || order.user.name).toLowerCase() : '' %>" data-id="<%= order._id %>">
                
                <div class="order-ref">
                    #<%= stringId.slice(-6).toUpperCase() %>
                </div>

                <div class="order-med" title="<%= order.medicineId ? order.medicineId.name : '' %>">
                    <%= order.medicineId ? order.medicineId.name : t.adminOrders.deletedMedicine %>
                </div>

                <div class="order-pharmacy" title="<%= order.user ? (order.user.pharmacy || order.user.name) : '' %>">
                    <%= order.user ? (order.user.pharmacy || order.user.name) : t.adminOrders.unknownUser %>
                </div>

                <div class="order-price">
                    ؋<%= order.totalPrice.toLocaleString() %>
                </div>

                <div>
                    <span class="badge <%= order.status.toLowerCase() %>" id="badge-<%= order._id %>"><%= order.status %></span>
                </div>

                <div class="order-actions-cell">
                    <button class="action-btn-sm" onclick="openDetailModal('<%- encodeURIComponent(JSON.stringify(order)) %>')" title="View Full Details">
                        <i class="ph ph-eye"></i>
                    </button>
                    
                    <div class="status-actions-wrapper" id="actions-<%= order._id %>" style="display: flex; gap: 6px;">
                        <% if(order.status.toLowerCase() === 'pending') { %>
                            <button class="action-btn-sm approve" onclick="updateStatus('<%= order._id %>', 'approved')" title="Approve">
                                <i class="ph ph-check" style="stroke-width: 30px;"></i>
                            </button>
                            <button class="action-btn-sm cancel" onclick="updateStatus('<%= order._id %>', 'cancelled')" title="Cancel">
                                <i class="ph ph-x" style="stroke-width: 30px;"></i>
                            </button>
                        <% } else { %>
                            <button class="action-btn-sm danger" onclick="openDeleteModal('<%= order._id %>')" title="Delete Record">
                                <i class="ph ph-trash" style="stroke-width: 30px;"></i>
                            </button>
                        <% } %>
                    </div>
                </div>

            </div>
        <% }) %>
    </div>
</div>

<div class="custom-backdrop" id="detailModal">
    <div class="modal-content-animated">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
            <h3 style="margin:0; font-size:1.2rem; display: flex; align-items: center; gap: 8px;">
                <i class="ph ph-receipt" style="color:var(--primary);"></i> Order Invoice
            </h3>
            <button type="button" onclick="closeDetailModal()" style="background: var(--surface-light); border: 1px solid var(--glass-border); border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; color: var(--text-main); cursor: pointer;"><i class="ph ph-x"></i></button>
        </div>
        
        <div id="modalDetailContent"></div>
    </div>
</div>

<div class="custom-backdrop" id="deleteModal">
    <div class="modal-content-animated" style="max-width: 400px; border-color: rgba(239, 68, 68, 0.3);">
        <h3 style="margin-top:0; font-size: 1.1rem; color: var(--danger); display: flex; align-items: center; gap: 8px;"><i class="ph ph-warning"></i> Remove Order</h3>
        <p style="font-size: 0.9rem; color: var(--text-main); margin-bottom: 20px;">Are you certain you want to purge this order from database logging?</p>
        
        <div class="modal-actions" style="display: flex; justify-content: flex-end; gap: 10px;">
            <button type="button" class="btn-outline" onclick="closeDeleteModal()">Cancel</button>
            <button type="button" class="btn-danger-sm" id="confirmDeleteBtn">Delete Order</button>
        </div>
    </div>
</div>

<script>
    let currentTabStatus = 'all';

    // ----- SEARCH AND TAB FILTERS NATIVE LOGIC -----
    function filterOrders() {
        const query = document.getElementById('searchInput').value.toLowerCase();
        const rows = document.querySelectorAll('.order-list-row');
        
        rows.forEach(row => {
            const med = row.dataset.med || '';
            const pharmacy = row.dataset.pharmacy || '';
            const status = row.dataset.status || '';
            
            const matchesSearch = med.includes(query) || pharmacy.includes(query);
            const matchesTab = currentTabStatus === 'all' || status === currentTabStatus;
            
            row.style.display = (matchesSearch && matchesTab) ? 'grid' : 'none';
        });
    }

    function filterTab(status, btn) {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentTabStatus = status.toLowerCase();
        filterOrders();
    }

    // ----- TOAST ALERTS HELPER -----
    function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        if (!container) return alert(message);
        
        const toast = document.createElement('div');
        const icon = type === 'success' ? '<i class="ph ph-check-circle"></i>' : '<i class="ph ph-warning-circle"></i>';
        toast.className = `toast ${type}`;
        toast.innerHTML = `${icon} <span>${message}</span>`;
        container.appendChild(toast);
        
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-20px)';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    // ----- DYNAMIC INVOICE MODALS PARSERS -----
    function openDetailModal(encodedJson) {
        const order = JSON.parse(decodeURIComponent(encodedJson));
        const medicineName = order.medicineId ? order.medicineId.name : '<%= t.adminOrders.deletedMedicine %>';
        const pharmacyName = order.user ? (order.user.pharmacy || order.user.name) : '<%= t.adminOrders.unknownUser %>';
        const orderDate = order.createdAt ? new Date(order.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'N/A';
        const quantity = order.quantity || 'N/A';

        const statusColors = {
            'pending': { color: 'var(--warning)', icon: 'ph-clock' },
            'approved': { color: 'var(--success)', icon: 'ph-check-circle' },
            'cancelled': { color: 'var(--danger)', icon: 'ph-x-circle' }
        };
        const sStyle = statusColors[order.status.toLowerCase()] || statusColors['pending'];

        const content = document.getElementById('modalDetailContent');
        content.innerHTML = `
            <div class="modal-info-group">
                <div class="info-item">
                    <div class="info-icon"><i class="ph ph-pill"></i></div>
                    <div class="info-text">
                        <span class="info-label">Medicine</span>
                        <span class="info-value" title="${medicineName}">${medicineName}</span>
                    </div>
                </div>
                <div class="info-item">
                    <div class="info-icon" style="color: #f59e0b; background: rgba(245,158,11,0.1);"><i class="ph ph-cube"></i></div>
                    <div class="info-text">
                        <span class="info-label">Quantity</span>
                        <span class="info-value">${quantity}</span>
                    </div>
                </div>
                <div class="info-item">
                    <div class="info-icon" style="color: #10b981; background: rgba(16,185,129,0.1);"><i class="ph ph-storefront"></i></div>
                    <div class="info-text">
                        <span class="info-label">Pharmacy</span>
                        <span class="info-value" title="${pharmacyName}">${pharmacyName}</span>
                    </div>
                </div>
                <div class="info-item">
                    <div class="info-icon" style="color: #a855f7; background: rgba(168,85,247,0.1);"><i class="ph ph-calendar-blank"></i></div>
                    <div class="info-text">
                        <span class="info-label">Date Requested</span>
                        <span class="info-value" style="font-size: 0.85rem;">${orderDate}</span>
                    </div>
                </div>
                <div class="info-item" style="grid-column: 1 / -1;">
                    <div class="info-icon" style="color: var(--text-muted); background: var(--surface-light);"><i class="ph ph-hash"></i></div>
                    <div class="info-text">
                        <span class="info-label">Reference ID</span>
                        <span class="info-value" style="font-family: monospace; font-size: 0.9rem; letter-spacing: 1px;">#${order._id.toString().toUpperCase()}</span>
                    </div>
                </div>
            </div>

            <div class="modal-total-row">
                <div style="display:flex; flex-direction:column; gap:4px;">
                    <span class="info-label" style="color: var(--text-muted);">Current Status</span>
                    <div style="display:flex; align-items:center; gap:6px; color: ${sStyle.color}; font-weight:800; font-size:1.2rem;">
                        <i class="ph ${sStyle.icon}"></i> <span style="text-transform: capitalize;">${order.status}</span>
                    </div>
                </div>
                <div style="text-align:right;">
                    <span class="info-label" style="display:block; color: var(--primary);">Total Invoice</span>
                    <span class="total-amount">؋${order.totalPrice.toLocaleString()}</span>
                </div>
            </div>

            ${order.notes ? `
            <div class="modal-notes">
                <div class="notes-header"><i class="ph ph-chat-text"></i> Customer Notes</div>
                <p>${order.notes}</p>
            </div>` : ''}

            <div class="modal-footer-actions">
                <button type="button" class="btn-outline" onclick="closeDetailModal()">Close Invoice</button>
            </div>
        `;
        document.getElementById('detailModal').style.display = 'flex';
    }
    function closeDetailModal() { document.getElementById('detailModal').style.display = 'none'; }

    // ----- DELETE FLOW MODALS OPERATORS -----
    let targetedDeleteId = null;
    function openDeleteModal(id) {
        targetedDeleteId = id;
        document.getElementById('deleteModal').style.display = 'flex';
    }
    function closeDeleteModal() {
        document.getElementById('deleteModal').style.display = 'none';
        targetedDeleteId = null;
    }

    window.onclick = function(e) {
        if (e.target === document.getElementById('detailModal')) closeDetailModal();
        if (e.target === document.getElementById('deleteModal')) closeDeleteModal();
    }

    // ----- PUT PIPELINE STATUS API CONTROLLER -----
    async function updateStatus(id, newStatus) {
        try {
            const res = await fetch(`/admin/orders/${id}/status`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: newStatus })
            });
            const result = await res.json();

            if (res.ok) {
                showToast(`Order status updated to ${newStatus}`, 'success');
                
                const row = document.getElementById(`row-${id}`);
                row.dataset.status = newStatus.toLowerCase();
                
                const badge = document.getElementById(`badge-${id}`);
                if (badge) {
                    badge.className = `badge ${newStatus.toLowerCase()}`;
                    badge.innerText = newStatus;
                }

                const actionsWrapper = document.getElementById(`actions-${id}`);
                if (actionsWrapper) {
                    actionsWrapper.innerHTML = `
                        <button class="action-btn-sm danger" onclick="openDeleteModal('${id}')" title="Delete Record">
                            <i class="ph ph-trash" style="stroke-width: 30px;"></i>
                        </button>
                    `;
                }
                filterOrders(); 
            } else {
                showToast(result.message || 'Status execution failed', 'error');
            }
        } catch (err) {
            showToast('Network pipeline update crashed', 'error');
        }
    }

    // ----- DELETE PIPELINE DATA DESTROYER -----
    document.getElementById('confirmDeleteBtn').addEventListener('click', async function() {
        if (!targetedDeleteId) return;
        this.disabled = true;
        this.innerText = '...';

        try {
            const res = await fetch(`/admin/orders/${targetedDeleteId}`, { method: 'DELETE' });
            if (res.ok) {
                document.getElementById(`row-${targetedDeleteId}`).remove();
                showToast('Order purged successfully', 'success');
            } else {
                showToast('Purge processing authorization rejected', 'error');
            }
        } catch (err) {
            showToast('Network connection pipeline failure', 'error');
        } finally {
            this.disabled = false;
            this.innerText = 'Delete Order';
            closeDeleteModal();
        }
    });
</script>

<%- include('partials/admin-footer', { page: 'orders' }) %>