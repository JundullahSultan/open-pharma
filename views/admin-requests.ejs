<%- include('partials/admin-header', { title: t.adminRequests.title, page: 'requests' }) %>

<style>
    .toolbar { margin-bottom: 15px; }
    .search-bar { display: flex; align-items: center; background: var(--surface-dark); border: 1px solid var(--glass-border); border-radius: 10px; padding: 10px 16px; gap: 12px; max-width: 450px; transition: border-color var(--transition-fast), box-shadow var(--transition-fast); }
    .search-bar:focus-within { border-color: var(--primary); box-shadow: 0 0 0 4px rgba(59,130,246,0.15); }
    .search-bar i { color: var(--text-muted); font-size: 1.2rem; }
    .search-bar:focus-within i { color: var(--primary); }
    .search-bar input { border: none; background: transparent; color: var(--text-main); outline: none; width: 100%; font-size: 0.95rem; font-family: inherit; }
    .search-bar input::placeholder { color: var(--text-muted); }

    .requests-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }

    .request-card {
        background: var(--surface-dark);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 14px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        box-shadow: var(--shadow-sm);
        transition: box-shadow var(--transition-fast), transform var(--transition-fast), border-color var(--transition-fast), opacity var(--transition-fast);
    }

    .request-card:hover {
        box-shadow: var(--shadow-md);
        transform: translateY(-1px);
    }

    .request-card.highlight {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(59,130,246,0.2);
    }

    .request-card-top { display: flex; justify-content: space-between; align-items: flex-start; }

    .request-card-medicine {
        font-weight: 600;
        color: var(--text-main);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 160px;
    }

    .request-card-company {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .request-card-qty {
        font-weight: 700;
        color: var(--text-main);
        white-space: nowrap;
    }

    .request-card-middle {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: var(--text-muted);
        font-size: 0.85rem;
    }

    .request-card-user {
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 140px;
    }

    .request-card-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
    }

    .request-card-action-group {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .eye-btn,
    .action-btn {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid var(--glass-border);
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .eye-btn { color: var(--text-muted); }
    .eye-btn:hover { color: var(--primary); background: rgba(59,130,246,0.1); border-color: var(--primary); }

    .action-btn.approve { color: var(--success); border-color: var(--success); }
    .action-btn.approve:hover { background: var(--success); color: white; }

    .action-btn.reject { color: var(--danger); border-color: var(--danger); }
    .action-btn.reject:hover { background: var(--danger); color: white; }

    .action-btn:disabled,
    .delete-req-btn:disabled,
    .eye-btn:disabled {
        opacity: 0.65;
        cursor: not-allowed;
        pointer-events: none;
    }

    .delete-req-btn {
        background: transparent;
        border: 1px solid var(--danger);
        color: var(--danger);
        padding: 6px 14px;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all var(--transition-fast);
    }

    .delete-req-btn:hover { background: var(--danger); color: white; }
</style>

<div class="toolbar">
    <div class="search-bar">
        <i class="ph ph-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="<%= t.adminRequests.searchPlaceholder || 'Search requests...' %>">
    </div>
</div>

<section class="card" style="margin: 0;">
    <div class="card-header">
        <h2><%= t.adminRequests.title %></h2>
    </div>

    <div class="requests-grid" id="requestsGrid">
        <% if (requests.length > 0) { %>
            <% requests.forEach(req => { %>
                <div
                    class="request-card"
                    id="req-<%= req._id %>"
                    data-search-text="<%= req.medicineName.toLowerCase() %> <%= req.companyName.toLowerCase() %> <%= req.user?.name?.toLowerCase() || '' %> <%= req.status.toLowerCase() %> <%= req.quantity %>"
                >
                    <div class="request-card-top">
                        <div>
                            <div class="request-card-medicine"><%= req.medicineName %></div>
                            <div class="request-card-company"><%= req.companyName %></div>
                        </div>
                        <span class="request-card-qty">x<%= req.quantity %></span>
                    </div>

                    <div class="request-card-middle">
                        <div class="request-card-user">
                            <i class="ph ph-user"></i>
                            <span><%= req.user ? req.user.name : (t.adminOrders.unknownUser || 'Unknown') %></span>
                        </div>

                        <span class="badge <%= req.status.toLowerCase() %>" id="badge-<%= req._id %>">
                            <%= req.status.toLowerCase() === 'approved'
                                ? (t.adminDashboard.approved || 'Approved')
                                : (req.status.toLowerCase() === 'rejected'
                                    ? (t.adminDashboard.cancelled || 'Rejected')
                                    : (t.adminDashboard.pending || 'Pending')) %>
                        </span>
                    </div>

                    <div class="request-card-actions">
                        <button
                            type="button"
                            class="eye-btn"
                            data-medicine="<%- req.medicineName || '' %>"
                            data-company="<%- req.companyName || '' %>"
                            data-shape="<%- req.shapeAndDose || '' %>"
                            data-trade="<%- req.tradeName || '' %>"
                            data-scientific="<%- req.scientificName || '' %>"
                            data-description="<%- req.description || '' %>"
                            title="<%= t.common.viewDetails || 'View details' %>"
                            style="display: none;"
                        >
                            <i class="ph ph-eye" ></i>
                        </button>

                        <div class="request-card-action-group">
                            <button
                                type="button"
                                class="delete-req-btn"
                                data-id="<%= req._id %>"
                                title="<%= t.common.delete || 'Delete' %>"
                            >
                                <i class="ph ph-trash"></i>
                            </button>

                            <% if (req.status === 'pending') { %>
                                <button
                                    type="button"
                                    class="action-btn approve"
                                    data-id="<%= req._id %>"
                                    data-status="approved"
                                    title="<%= t.adminDashboard.approved || 'Approve' %>"
                                >
                                    <i class="ph ph-check"></i>
                                </button>

                                <button
                                    type="button"
                                    class="action-btn reject"
                                    data-id="<%= req._id %>"
                                    data-status="rejected"
                                    title="<%= t.adminDashboard.cancelled || 'Reject' %>"
                                >
                                    <i class="ph ph-x"></i>
                                </button>
                            <% } %>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div id="emptyState" class="empty-state" style="grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--text-muted);">
                <i class="ph ph-hand-waving" style="font-size: 3rem; margin-bottom: 10px;"></i>
                <p><%= t.userRequest.noRequests || 'No requests found.' %></p>
            </div>
        <% } %>
    </div>
</section>

<div class="modal-backdrop" id="detailsModal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9999; align-items: center; justify-content: center; padding: 20px; backdrop-filter: blur(4px);">
    <div class="modal-content" style="background: var(--surface-dark); border: 1px solid var(--glass-border); border-radius: 12px; padding: 24px; width: 100%; max-width: 550px; max-height: 90vh; overflow-y: auto; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
        <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid var(--glass-border); padding-bottom: 15px;">
            <h2 style="margin: 0; color: var(--text-main);"><%= t.adminRequests.modalTitle || 'Request Details' %></h2>
            <button type="button" onclick="closeModal('detailsModal')" style="background: transparent; border: none; font-size: 1.5rem; cursor: pointer; color: var(--text-muted);">
                <i class="ph ph-x"></i>
            </button>
        </div>

        <div id="modalBody" style="display: flex; flex-direction: column; gap: 16px;"></div>

        <div class="modal-actions" style="margin-top: 24px; display: flex; justify-content: flex-end;">
            <button
                type="button"
                class="btn-cancel"
                style="padding: 10px 20px; border-radius: 8px; cursor: pointer; font-family: inherit; font-weight: 500;"
                onclick="closeModal('detailsModal')"
            >
                <%= t.common.cancel || 'Close' %>
            </button>
        </div>
    </div>
</div>

<div id="toast-container" style="position: fixed; top: 20px; right: 20px; z-index: 10000; display: flex; flex-direction: column; gap: 10px;"></div>

<script>
    const texts = {
        noDescription: <%- JSON.stringify(t.adminRequests.noDescription || 'No description provided') %>,
        medicine: <%- JSON.stringify(t.adminRequests.medicine || 'Medicine') %>,
        company: <%- JSON.stringify(t.adminMedicines.company || 'Company') %>,
        shapeDose: <%- JSON.stringify(t.adminRequests.shapeDose || 'Shape & Dose') %>,
        tradeName: <%- JSON.stringify(t.userRequest.tradeName || 'Trade Name') %>,
        scientificName: <%- JSON.stringify(t.userRequest.scientificName || 'Scientific Name') %>,
        description: <%- JSON.stringify(t.userRequest.description || 'Description') %>,
        processing: <%- JSON.stringify(t.common.processing || 'Processing...') %>,
        approved: <%- JSON.stringify(t.adminDashboard.approved || 'Approved') %>,
        rejected: <%- JSON.stringify(t.adminDashboard.cancelled || 'Rejected') %>,
        success: <%- JSON.stringify(t.common.success || 'Success') %>,
        deleteSuccess: <%- JSON.stringify(t.common.success || 'Request deleted successfully') %>,
        updateError: <%- JSON.stringify(t.adminRequests.errorUpdate || 'Error updating status') %>,
        deleteError: <%- JSON.stringify(t.common.error || 'Failed to delete request') %>,
        networkError: <%- JSON.stringify(t.adminRequests.networkError || 'Network Error') %>,
        noRequests: <%- JSON.stringify(t.userRequest.noRequests || 'No requests found.') %>
    };

    document.querySelectorAll('.modal-backdrop').forEach(overlay => {
        overlay.addEventListener('click', (e) => {
            if (e.target === overlay) closeModal(overlay.id);
        });
    });

    window.closeModal = function(modalId) {
        const modal = document.getElementById(modalId);
        if (modal) modal.style.display = 'none';
    };

    function escapeHtml(value) {
        return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function showToast(message, type = 'success') {
        const toastContainer = document.getElementById('toast-container');
        const toast = document.createElement('div');
        const icon = type === 'success' ? '<i class="ph ph-check-circle"></i>' : '<i class="ph ph-warning-circle"></i>';
        const borderColor = type === 'success' ? 'var(--success)' : 'var(--danger)';

        toast.style.cssText = `
            background: var(--surface-dark);
            border-left: 4px solid ${borderColor};
            color: var(--text-main);
            padding: 14px 20px;
            border-radius: 8px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            display: flex;
            align-items: center;
            gap: 12px;
            transition: all 0.3s ease;
            opacity: 0;
            transform: translateX(50px);
            font-weight: 500;
            font-size: 0.95rem;
        `;

        toast.innerHTML = `${icon} <span>${escapeHtml(message)}</span>`;
        toastContainer.appendChild(toast);

        requestAnimationFrame(() => {
            toast.style.opacity = '1';
            toast.style.transform = 'translateX(0)';
        });

        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(50px)';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    function openDetailsModal(req) {
        const desc = req.description || texts.noDescription;

        const body = document.getElementById('modalBody');
        body.innerHTML = `
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px; background: rgba(0,0,0,0.15); padding: 16px; border-radius: 12px; border: 1px solid var(--glass-border);">
                <div>
                    <strong style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">${escapeHtml(texts.medicine)}</strong><br>
                    <span style="font-weight:600; color:var(--text-main);">${escapeHtml(req.medicineName || '-')}</span>
                </div>

                <div>
                    <strong style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">${escapeHtml(texts.company)}</strong><br>
                    <span style="font-weight:600; color:var(--text-main);">${escapeHtml(req.companyName || '-')}</span>
                </div>

                <div>
                    <strong style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">${escapeHtml(texts.shapeDose)}</strong><br>
                    <span style="font-weight:600; color:var(--text-main);">${escapeHtml(req.shapeAndDose || '-')}</span>
                </div>

                <div>
                    <strong style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">${escapeHtml(texts.tradeName)}</strong><br>
                    <span style="font-weight:600; color:var(--text-main);">${escapeHtml(req.tradeName || '-')}</span>
                </div>

                <div style="grid-column: 1 / -1;">
                    <strong style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">${escapeHtml(texts.scientificName)}</strong><br>
                    <span style="font-weight:600; color:var(--text-main);">${escapeHtml(req.scientificName || '-')}</span>
                </div>
            </div>

            <div>
                <strong style="color:var(--text-muted); font-size:0.75rem; text-transform:uppercase; letter-spacing:0.5px;">${escapeHtml(texts.description)}</strong>
                <div style="margin-top:6px; background: rgba(0,0,0,0.15); border: 1px solid var(--glass-border); padding:16px; border-radius:12px; line-height: 1.6; color:var(--text-main); white-space: pre-wrap;">${escapeHtml(desc)}</div>
            </div>
        `;

        document.getElementById('detailsModal').style.display = 'flex';
    }

    async function updateRequestStatus(id, status, btn) {
        const originalHTML = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="ph ph-spinner ph-spin"></i>';

        const siblingButtons = btn.parentElement.querySelectorAll('.action-btn');
        siblingButtons.forEach(button => {
            button.disabled = true;
        });

        try {
            const res = await fetch(`/admin/requests/${id}/status`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });

            if (res.ok) {
                const badge = document.getElementById(`badge-${id}`);
                if (badge) {
                    badge.className = `badge ${status}`;
                    badge.innerText = status === 'approved' ? texts.approved : texts.rejected;
                }

                const card = document.getElementById(`req-${id}`);
                if (card) {
                    const actionsDiv = card.querySelector('.request-card-action-group');
                    if (actionsDiv) {
                        const approveBtn = actionsDiv.querySelector('.action-btn.approve');
                        const rejectBtn = actionsDiv.querySelector('.action-btn.reject');
                        if (approveBtn) approveBtn.remove();
                        if (rejectBtn) rejectBtn.remove();
                    }

                    const searchText = card.dataset.searchText || '';
                    card.dataset.searchText = searchText
                        .replace(/\bpending\b/i, '')
                        .trim() + ' ' + status;
                }

                showToast(texts.success, 'success');
            } else {
                btn.innerHTML = originalHTML;
                siblingButtons.forEach(button => button.disabled = false);
                showToast(texts.updateError, 'error');
            }
        } catch (err) {
            console.error(err);
            btn.innerHTML = originalHTML;
            siblingButtons.forEach(button => button.disabled = false);
            showToast(texts.networkError, 'error');
        }
    }

    async function deleteRequest(id, btn) {
        const originalHTML = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<i class="ph ph-spinner ph-spin"></i>';

        try {
            const res = await fetch(`/admin/requests/${id}`, { method: 'DELETE' });

            if (res.ok) {
                const card = document.getElementById(`req-${id}`);
                if (card) card.remove();

                const remainingCards = document.querySelectorAll('.request-card');
                if (remainingCards.length === 0) {
                    const grid = document.getElementById('requestsGrid');
                    grid.innerHTML = `
                        <div id="emptyState" class="empty-state" style="grid-column: 1 / -1; text-align: center; padding: 40px; color: var(--text-muted);">
                            <i class="ph ph-hand-waving" style="font-size: 3rem; margin-bottom: 10px;"></i>
                            <p>${escapeHtml(texts.noRequests)}</p>
                        </div>
                    `;
                }

                showToast(texts.deleteSuccess, 'success');
            } else {
                btn.disabled = false;
                btn.innerHTML = originalHTML;
                showToast(texts.deleteError, 'error');
            }
        } catch (err) {
            console.error(err);
            btn.disabled = false;
            btn.innerHTML = originalHTML;
            showToast(texts.networkError, 'error');
        }
    }

    const requestsGrid = document.getElementById('requestsGrid');

    requestsGrid.addEventListener('click', function(e) {
        const eyeBtn = e.target.closest('.eye-btn');
        if (eyeBtn) {
            openDetailsModal({
                medicineName: eyeBtn.dataset.medicine || '',
                companyName: eyeBtn.dataset.company || '',
                shapeAndDose: eyeBtn.dataset.shape || '',
                tradeName: eyeBtn.dataset.trade || '',
                scientificName: eyeBtn.dataset.scientific || '',
                description: eyeBtn.dataset.description || ''
            });
            return;
        }

        const approveBtn = e.target.closest('.action-btn.approve');
        if (approveBtn) {
            updateRequestStatus(approveBtn.dataset.id, 'approved', approveBtn);
            return;
        }

        const rejectBtn = e.target.closest('.action-btn.reject');
        if (rejectBtn) {
            updateRequestStatus(rejectBtn.dataset.id, 'rejected', rejectBtn);
            return;
        }

        const deleteBtn = e.target.closest('.delete-req-btn');
        if (deleteBtn) {
            deleteRequest(deleteBtn.dataset.id, deleteBtn);
        }
    });

    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            const term = this.value.toLowerCase().trim();
            const requestCards = document.querySelectorAll('.request-card');

            requestCards.forEach(card => {
                const searchText = (card.dataset.searchText || '').toLowerCase();
                const matches = !term || searchText.includes(term);

                card.style.display = matches ? 'flex' : 'none';

                if (matches && term) {
                    card.classList.add('highlight');
                } else {
                    card.classList.remove('highlight');
                }
            });
        });
    }
</script>

<%- include('partials/admin-footer', { page: 'requests' }) %>