<%- include('partials/admin-header', { title: t.adminUsers.title, page: 'users' }) %>

<style>
    /* Layout grid */
    .users-layout {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
        align-items: start;
        margin-top: 20px;
    }
    @media (max-width: 992px) {
        .users-layout { grid-template-columns: 1fr; }
    }

    /* Table: visible on desktop, hidden on mobile */
    .users-table-card { display: block; }
    @media (max-width: 768px) {
        .users-table-card { display: none; }
    }

    /* Mobile‑first card list (hidden on desktop) */
    .users-mobile-list {
        display: none;
        flex-direction: column;
        gap: 10px;
    }
    @media (max-width: 768px) {
        .users-mobile-list { display: flex; }
    }

    .user-mobile-card {
        background: var(--surface-dark);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 1rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        box-shadow: var(--shadow-sm);
    }
    .user-mobile-info {
        display: flex;
        align-items: center;
        gap: 12px;
        flex: 1;
        min-width: 0;
    }
    .user-mobile-name {
        font-weight: 600;
        color: var(--text-main);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .user-mobile-pharmacy {
        font-size: 0.85rem;
        color: var(--text-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .user-mobile-actions {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .eye-btn {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid var(--glass-border);
        background: transparent;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all var(--transition-fast);
    }
    .eye-btn:hover {
        color: var(--primary);
        background: rgba(59,130,246,0.1);
        border-color: var(--primary);
    }

    /* Modal for user details */
    #userDetailModal .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }
    #userDetailModal .detail-grid p { margin: 0; color: var(--text-main); }
    #userDetailModal .detail-grid strong {
        display: block;
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 2px;
    }
</style>

<div class="toolbar">
    <div class="search-bar">
        <i class="ph ph-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="<%= t.adminUsers.searchPlaceholder %>">
    </div>
</div>

<div class="users-layout">
    
    <section class="card users-table-card" style="margin: 0;">
        <div style="overflow-x: auto;">
            <table>
                <thead>
                    <tr>
                        <th><%= t.common.name %></th>
                        <th><%= t.auth.pharmacyName %></th>
                        <th><%= t.common.email %></th>
                        <th><%= t.common.role %></th>
                        <th><%= t.adminUsers.joined %></th>
                        <th><%= t.common.actions %></th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                    <tr id="row-<%= user._id %>">
                        <td>
                            <div class="user-info">
                                <div class="avatar-sm">
                                    <% if(user.imageURL) { %>
                                        <img src="<%= user.imageURL %>" alt="<%= user.name %>">
                                    <% } else { %>
                                        <span style="font-weight: bold; color: var(--text-muted);"><%= user.name[0].toUpperCase() %></span>
                                    <% } %>
                                </div>
                                <span style="font-weight: 500;"><%= user.name %></span>
                            </div>
                        </td>
                        <td><%= user.pharmacy %></td>
                        <td><%= user.email %></td>
                        <td>
                            <span class="badge <%= user.role === 'admin' ? 'approved' : 'pending' %>">
                                <%= user.role %>
                            </span>
                        </td>
                        <td><%= user.createdAt ? new Date(user.createdAt).toLocaleDateString() : 'N/A' %></td>
                        <td>
                            <div class="actions">
                                <% if (user.email !== 'suhrab@gmail.com') { %>
                                    <button class="btn-icon cancel" title="<%= t.common.delete %>" onclick="deleteUser('<%= user._id%>')">
                                        <i class="ph ph-trash"></i>
                                    </button>
                                <% } else { %>
                                    <span class="badge approved" style="background: var(--surface-light); color: var(--text-muted);">
                                        <i class="ph ph-lock-key"></i> Protected
                                    </span>
                                <% } %>
                            </div>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </section>

    <section class="card users-mobile-list" style="margin: 0;">
        <div class="card-header">
            <h2 style="margin: 0;"><%= t.adminUsers.title %></h2>
        </div>
        <% users.forEach((user) => { %>
        <div class="user-mobile-card" id="mobile-row-<%= user._id %>">
            <div class="user-mobile-info">
                <div class="avatar-sm">
                    <% if(user.imageURL) { %>
                        <img src="<%= user.imageURL %>" alt="<%= user.name %>">
                    <% } else { %>
                        <span style="font-weight: bold; color: var(--text-muted);"><%= user.name[0].toUpperCase() %></span>
                    <% } %>
                </div>
                <div style="flex:1; min-width:0;">
                    <div class="user-mobile-name"><%= user.name %></div>
                    <div class="user-mobile-pharmacy"><%= user.pharmacy %></div>
                </div>
            </div>
            <div class="user-mobile-actions">
                
                <button class="eye-btn" 
                        data-user="<%= encodeURIComponent(JSON.stringify(user)) %>"
                        onclick="openUserDetail(this)" 
                        title="View details">
                    <i class="ph ph-eye"></i>
                </button>

                <% if (user.email !== 'suhrab@gmail.com') { %>
                    <button class="btn-icon cancel" onclick="deleteUser('<%= user._id%>')" title="<%= t.common.delete %>">
                        <i class="ph ph-trash"></i>
                    </button>
                <% } else { %>
                    <span class="badge approved" style="background: var(--surface-light); color: var(--text-muted); font-size:0.7rem;">
                        <i class="ph ph-lock-key"></i> 
                    </span>
                <% } %>
            </div>
        </div>
        <% }) %>
    </section>

    <section class="card create-user" style="margin: 0;">
        <div class="card-header" style="margin-bottom: 15px; padding-bottom: 15px; border-bottom: 1px solid var(--glass-border);">
            <h2 style="margin: 0;"><%= t.adminUsers.addNew %></h2>
        </div>

        <form id="createUserForm" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 15px;">
            <div class="form-group">
                <label style="display: block; margin-bottom: 5px; font-weight: 500;"><%= t.common.name %></label>
                <input type="text" name="name" required>
            </div>
            <div class="form-group">
                <label style="display: block; margin-bottom: 5px; font-weight: 500;"><%= t.auth.pharmacyName %></label>
                <input type="text" name="pharmacy" required>
            </div>
            <div class="form-group">
                <label style="display: block; margin-bottom: 5px; font-weight: 500;"><%= t.common.email %></label>
                <input type="email" name="email" required>
            </div>
            <div class="form-group">
                <label style="display: block; margin-bottom: 5px; font-weight: 500;"><%= t.auth.password %></label>
                <input type="password" name="password" required>
            </div>
            <div class="form-group">
                <label style="display: block; margin-bottom: 5px; font-weight: 500;"><%= t.common.role %></label>
                <select name="role">
                    <option value="user">User</option>
                    <option value="admin">Admin</option>
                </select>
            </div>
            
            <div class="form-group">
                <label style="display: block; margin-bottom: 5px; font-weight: 500;">Profile Photo</label>
                <input type="file" name="imageURL" accept="image/*">
            </div>

            <button type="submit" class="btn-primary" style="margin-top: 10px; width: 100%;">Create User</button>
        </form>
    </section>
</div>

<div class="modal-backdrop" id="userDetailModal" style="display:none;">
    <div class="modal-content" style="max-width: 450px;">
        <div class="card-header" style="margin-bottom: 1rem;">
            <h3 style="margin:0;">User Details</h3>
        </div>
        <div id="userDetailContent"></div>
        <div class="modal-actions">
            <button class="btn-cancel" onclick="closeUserDetail()">Close</button>
        </div>
    </div>
</div>

<div id="deleteModal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 9999; align-items: center; justify-content: center;">
    <div style="background: var(--surface); border-radius: 12px; padding: 20px; width: 90%; max-width: 400px; text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
        <div style="width: 50px; height: 50px; border-radius: 50%; background: #fee2e2; display: flex; align-items: center; justify-content: center; color: #ef4444; font-size: 24px; margin: 0 auto 15px;">
            <i class="ph ph-warning-circle"></i>
        </div>
        <h3 style="margin: 0 0 10px; color: var(--text-main);">Delete User?</h3>
        <p style="margin: 0 0 20px; color: var(--text-muted); font-size: 0.95rem;">
            Are you sure you want to delete this user? This action cannot be undone.
        </p>
        <div style="display: flex; gap: 10px; width: 100%;">
            <button id="cancelBtn" class="btn-secondary" style="flex: 1; padding: 10px; border-radius: 8px; border: 1px solid var(--glass-border); background: var(--surface-light); color: var(--text-main); cursor: pointer;">
                Cancel
            </button>
            <button id="confirmDeleteBtn" class="btn-primary" style="flex: 1; padding: 10px; border-radius: 8px; background: #ef4444; color: white; border: none; cursor: pointer;">
                Yes, Delete
            </button>
        </div>
    </div>
</div>

<script>
    // READS ENCODED JSON DATA SAFELY
    function openUserDetail(btn) {
        try {
            // Safely parse the hidden user data attached to the button
            const encodedData = btn.getAttribute('data-user');
            const user = JSON.parse(decodeURIComponent(encodedData));
            
            // Format dates and roles
            const joinedDate = user.createdAt ? new Date(user.createdAt).toLocaleDateString() : 'N/A';
            const roleBadge = user.role === 'admin' ? 'approved' : 'pending';

            const content = document.getElementById('userDetailContent');
            content.innerHTML = `
                <div class="detail-grid">
                    <p><strong>Name</strong> ${user.name || 'N/A'}</p>
                    <p><strong>Pharmacy</strong> ${user.pharmacy || 'N/A'}</p>
                    <p><strong>Email</strong> ${user.email || 'N/A'}</p>
                    <p><strong>Role</strong> <span class="badge ${roleBadge}">${user.role || 'user'}</span></p>
                    <p><strong>Joined</strong> ${joinedDate}</p>
                    <p><strong>ID</strong> <code style="font-size:0.8rem;">${user._id}</code></p>
                </div>
                ${user.imageURL ? `<img src="${user.imageURL}" alt="${user.name}" style="width:100px; height:100px; border-radius:50%; object-fit:cover; margin:0 auto; display:block; border:2px solid var(--glass-border);" />` : ''}
            `;

            // CRITICAL FIX: Explicitly override CSS opacity:0 to make the box visible
            const modal = document.getElementById('userDetailModal');
            const innerBox = modal.querySelector('.modal-content');
            
            modal.style.display = 'flex';
            innerBox.style.display = 'block';
            innerBox.style.opacity = '1';
            
        } catch(err) {
            console.error("Error reading user data", err);
        }
    }

    function closeUserDetail() {
        const modal = document.getElementById('userDetailModal');
        const innerBox = modal.querySelector('.modal-content');
        
        modal.style.display = 'none';
        innerBox.style.display = 'none';
        innerBox.style.opacity = '0';
    }

    // Close modal when clicking backdrop
    document.getElementById('userDetailModal').addEventListener('click', function(e) {
        if (e.target === this) closeUserDetail();
    });

    // Create user fetch logic
    document.getElementById('createUserForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        const submitBtn = this.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerText;
        
        submitBtn.innerText = 'Creating...';
        submitBtn.disabled = true;
        
        try {
            const response = await fetch('/admin/users', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();
            
            if (response.ok) {
                window.location.reload();
            } else {
                alert('Error: ' + (result.message || 'Failed to create user'));
                submitBtn.innerText = originalText;
                submitBtn.disabled = false;
            }
        } catch (err) {
            console.error(err);
            alert('A network error occurred.');
            submitBtn.innerText = originalText;
            submitBtn.disabled = false;
        }
    });
</script>

<script src="/js/admin-user.js"></script>

<%- include('partials/admin-footer', { page: 'users' }) %>