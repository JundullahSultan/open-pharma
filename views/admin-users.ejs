<%- include('partials/admin-header', { title: t.adminUsers.title, page: 'users' }) %>

<style>
    /* ===== TOOLBAR & SEARCH ===== */
    .toolbar { 
        margin-bottom: 16px; 
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .search-bar {
        display: flex;
        align-items: center;
        background: var(--surface-dark);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        padding: 8px 14px;
        gap: 10px;
        transition: all 0.2s ease;
        max-width: 400px;
        width: 100%;
        box-shadow: var(--shadow-sm);
    }
    .search-bar:focus-within {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
    }
    .search-bar i { color: var(--text-muted); font-size: 1.1rem; }
    .search-bar:focus-within i { color: var(--primary); }
    .search-bar input {
        border: none; background: transparent; color: var(--text-main);
        outline: none; width: 100%; font-size: 0.9rem; font-family: inherit;
    }
    .search-bar input::placeholder { color: var(--text-muted); }

    /* ===== LAYOUT & GRID ===== */
    .users-layout {
        display: grid;
        grid-template-columns: 2.5fr 1fr; /* Prioritize the user list space */
        gap: 16px;
        align-items: start;
    }
    @media (max-width: 992px) {
        .users-layout { grid-template-columns: 1fr; }
    }

    /* ===== USER LIST (COMPACT) ===== */
    .user-list-header {
        display: grid;
        grid-template-columns: 2.5fr 2fr 1.5fr 1fr 80px;
        gap: 12px;
        padding: 0 16px 8px 16px;
        font-size: 0.75rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 700;
        border-bottom: 1px solid var(--glass-border);
        margin-bottom: 8px;
    }

    .user-card-row {
        display: grid;
        grid-template-columns: 2.5fr 2fr 1.5fr 1fr 80px;
        gap: 12px;
        align-items: center;
        padding: 10px 16px;
        background: linear-gradient(145deg, var(--surface-dark) 0%, rgba(255,255,255,0.01) 100%);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        margin-bottom: 6px;
        transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: var(--shadow-sm);
    }
    .user-card-row:hover {
        border-color: rgba(59, 130, 246, 0.4);
        box-shadow: var(--shadow-md);
        transform: translateX(4px); /* Sleek slide-right effect */
    }

    .user-info-col {
        display: flex;
        align-items: center;
        gap: 12px;
        overflow: hidden;
    }
    .user-avatar {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: rgba(59, 130, 246, 0.1);
        color: var(--primary);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 0.9rem;
        flex-shrink: 0;
        border: 1px solid rgba(59, 130, 246, 0.2);
    }
    .user-avatar img {
        width: 100%; height: 100%; object-fit: cover; border-radius: 8px;
    }
    
    .user-details {
        display: flex; flex-direction: column; overflow: hidden;
    }
    .user-name { font-weight: 600; color: var(--text-main); font-size: 0.95rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-email { color: var(--text-muted); font-size: 0.75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .user-pharmacy { font-size: 0.85rem; color: var(--text-main); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    /* Compact Pill Badges */
    .badge {
        padding: 2px 8px;
        font-size: 0.65rem;
        border-radius: 20px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: inline-block;
        width: fit-content;
    }
    .badge.admin { background: rgba(168,85,247,0.15); color: #c084fc; border: 1px solid rgba(168,85,247,0.2); }
    .badge.user { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.2); }

    .user-date { font-size: 0.8rem; color: var(--text-muted); }

    /* Miniaturized Action Buttons */
    .user-actions {
        display: flex;
        gap: 6px;
        justify-content: flex-end;
    }
    .action-btn-sm {
        width: 28px;
        height: 28px;
        border-radius: 6px;
        border: 1px solid var(--glass-border);
        background: var(--surface-light);
        color: var(--text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 1rem;
    }
    .action-btn-sm:hover { color: var(--primary); background: rgba(59, 130, 246, 0.15); border-color: var(--primary); }
    .action-btn-sm.danger:hover { color: var(--danger); background: rgba(239, 68, 68, 0.15); border-color: var(--danger); }

    /* Responsive Grid Fallback for Mobile */
    @media (max-width: 768px) {
        .user-list-header { display: none; }
        .user-card-row {
            grid-template-columns: 1fr;
            gap: 8px;
            padding: 12px;
        }
        .user-pharmacy, .user-date { display: flex; align-items: center; gap: 6px; }
        .user-pharmacy::before { content: "Pharmacy: "; color: var(--text-muted); font-size: 0.75rem; }
        .user-date::before { content: "Joined: "; color: var(--text-muted); font-size: 0.75rem; }
        .user-actions { justify-content: flex-start; margin-top: 8px; border-top: 1px dashed var(--glass-border); padding-top: 10px;}
    }

    /* ===== CREATE USER FORM (PREMIUM COMPACT) ===== */
    .create-user-card {
        background: linear-gradient(135deg, var(--surface-dark) 0%, rgba(59, 130, 246, 0.05) 100%);
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 12px;
        padding: 16px;
        margin: 0;
        box-shadow: var(--shadow-sm);
    }
    .create-user-card h3 {
        margin-top: 0;
        margin-bottom: 16px;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .create-user-card h3 i { color: var(--primary); }
    
    .form-group-compact {
        margin-bottom: 12px;
    }
    .form-group-compact label {
        display: block;
        margin-bottom: 4px;
        font-size: 0.8rem;
        color: var(--text-muted);
        font-weight: 600;
    }
    .form-group-compact input, .form-group-compact select {
        width: 100%;
        padding: 8px 12px;
        background: var(--bg-dark);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        color: var(--text-main);
        font-size: 0.9rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        outline: none;
    }
    .form-group-compact input:focus, .form-group-compact select:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
    }
    
    .btn-create {
        width: 100%;
        padding: 10px;
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 6px;
        margin-top: 4px;
    }
    .btn-create:hover { background: #2563eb; }

    /* ===== COMPACT MODALS ===== */
    .custom-backdrop {
        display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 9999;
        align-items: center; justify-content: center;
    }
    .modal-content-animated {
        background: var(--surface-dark); border: 1px solid var(--glass-border);
        border-radius: 16px; padding: 20px; width: 90%; max-width: 400px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
        animation: slideUpFade 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; }
    .btn-outline { background: transparent; border: 1px solid var(--glass-border); color: var(--text-main); padding: 8px 16px; border-radius: 8px; cursor: pointer; }
    .btn-outline:hover { background: var(--surface-light); }
    .btn-danger { background: var(--danger); color: white; border: none; padding: 8px 16px; border-radius: 8px; cursor: pointer; }
    .btn-danger:hover { background: #dc2626; }
</style>

<div id="toast-container"></div>

<div class="toolbar">
    <div class="search-bar">
        <i class="ph ph-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="<%= t.adminUsers.searchPlaceholder %>" onkeyup="filterUsers()">
    </div>
</div>

<div class="users-layout">

    <aside>
        <section class="create-user-card">
            <h3><i class="ph ph-user-plus"></i> <%= t.adminUsers.addNewUser %></h3>
            <form id="createUserForm">
                <div class="form-group-compact">
                    <label><%= t.adminUsers.formName %></label>
                    <input type="text" name="name" required placeholder="John Doe">
                </div>
                
                <div class="form-group-compact">
                    <label><%= t.adminUsers.formEmail %></label>
                    <input type="email" name="email" required placeholder="john@example.com">
                </div>
                
                <div class="form-group-compact">
                    <label><%= t.adminUsers.formPassword %></label>
                    <input type="password" name="password" required placeholder="••••••••">
                </div>
                
                <div class="form-group-compact">
                    <label><%= t.adminUsers.formPharmacy %></label>
                    <input type="text" name="pharmacy" placeholder="City Pharmacy (Optional)">
                </div>
                
                <div class="form-group-compact">
                    <label><%= t.adminUsers.formRole %></label>
                    <select name="role">
                        <option value="user">User</option>
                        <option value="admin">Admin</option>
                    </select>
                </div>
                
                <button type="submit" class="btn-create">
                    <i class="ph ph-plus-circle"></i> <%= t.adminUsers.btnCreate %>
                </button>
            </form>
        </section>
    </aside>
    
    <div class="users-list-container">
        <div class="user-list-header">
            <div>User</div>
            <div>Pharmacy</div>
            <div>Role</div>
            <div>Joined</div>
            <div style="text-align: right;">Actions</div>
        </div>

        <div id="userGrid">
            <% users.forEach(u => { %>
                <div class="user-card-row" data-name="<%= u.name.toLowerCase() %>" data-email="<%= u.email.toLowerCase() %>" data-pharmacy="<%= (u.pharmacy || '').toLowerCase() %>">
                    
                    <div class="user-info-col">
                        <div class="user-avatar">
                            <% if(u.imageURL) { %>
                                <img src="<%= u.imageURL %>" alt="<%= u.name %>">
                            <% } else { %>
                                <%= u.name.charAt(0).toUpperCase() %>
                            <% } %>
                        </div>
                        <div class="user-details">
                            <span class="user-name"><%= u.name %></span>
                            <span class="user-email"><%= u.email %></span>
                        </div>
                    </div>

                    <div class="user-pharmacy">
                        <%= u.pharmacy || '-' %>
                    </div>

                    <div>
                        <span class="badge <%= u.role === 'admin' ? 'admin' : 'user' %>"><%= u.role %></span>
                    </div>

                    <div class="user-date">
                        <%= new Date(u.createdAt).toLocaleDateString() %>
                    </div>

                    <div class="user-actions">
                        <button class="action-btn-sm" onclick="openResetModal('<%= u._id %>')" title="Reset Password">
                            <i class="ph ph-key"></i>
                        </button>
                        <button class="action-btn-sm danger" onclick="openDeleteModal('<%= u._id %>', '<%= u.name %>')" title="Delete User">
                            <i class="ph ph-trash"></i>
                        </button>
                    </div>

                </div>
            <% }) %>
        </div>
        
        <% if(users.length === 0) { %>
            <div style="text-align:center; padding: 40px; color: var(--text-muted); background: var(--surface-dark); border-radius: 12px; border: 1px dashed var(--glass-border);">
                <i class="ph ph-users" style="font-size: 3rem; margin-bottom: 10px; opacity: 0.5;"></i>
                <p>No users found in the system.</p>
            </div>
        <% } %>
    </div>

    
</div>

<div class="custom-backdrop" id="resetModal">
    <div class="modal-content-animated">
        <h3 style="margin-top:0; font-size: 1.1rem; display: flex; align-items: center; gap: 8px;"><i class="ph ph-key" style="color:var(--primary);"></i> Reset Password</h3>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 16px;">Enter a new password for this user.</p>
        
        <input type="hidden" id="resetUserId">
        <div class="form-group-compact">
            <input type="password" id="newPassword" placeholder="New Password" required style="width: 100%; box-sizing: border-box;">
        </div>
        
        <div class="modal-actions">
            <button class="btn-outline" onclick="closeResetModal()">Cancel</button>
            <button class="btn-create" style="width: auto; margin: 0; padding: 8px 16px;" id="confirmResetBtn">Save Password</button>
        </div>
    </div>
</div>

<div class="custom-backdrop" id="deleteModal">
    <div class="modal-content-animated" style="border-color: rgba(239, 68, 68, 0.3);">
        <h3 style="margin-top:0; font-size: 1.1rem; color: var(--danger); display: flex; align-items: center; gap: 8px;"><i class="ph ph-warning"></i> Confirm Deletion</h3>
        <p style="font-size: 0.9rem; color: var(--text-main); margin-bottom: 20px;">Are you sure you want to delete <strong id="deleteUserName"></strong>?</p>
        
        <div class="modal-actions">
            <button class="btn-outline" onclick="closeDeleteModal()">Cancel</button>
            <button class="btn-danger" id="confirmDeleteBtn">Delete User</button>
        </div>
    </div>
</div>

<script>
    // ----- TOAST HELPER -----
    function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        if (!container) return alert(message);
        
        const toast = document.createElement('div');
        const icon = type === 'success' ? '<i class="ph ph-check-circle"></i>' : '<i class="ph ph-warning-circle"></i>';
        toast.className = `toast ${type}`;
        toast.innerHTML = `${icon} <span>${message}</span>`;
        container.appendChild(toast);
        
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-20px)';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    // ----- SEARCH FILTER -----
    function filterUsers() {
        const query = document.getElementById('searchInput').value.toLowerCase();
        const rows = document.querySelectorAll('.user-card-row');
        
        rows.forEach(row => {
            const name = row.dataset.name || '';
            const email = row.dataset.email || '';
            const pharmacy = row.dataset.pharmacy || '';
            
            if (name.includes(query) || email.includes(query) || pharmacy.includes(query)) {
                row.style.display = 'grid'; // Maintain grid layout
            } else {
                row.style.display = 'none';
            }
        });
    }

    // ----- MODAL HANDLERS -----
    let deleteUserId = null;

    function openResetModal(userId) {
        document.getElementById('resetUserId').value = userId;
        document.getElementById('newPassword').value = '';
        document.getElementById('resetModal').style.display = 'flex';
    }
    function closeResetModal() {
        document.getElementById('resetModal').style.display = 'none';
    }

    function openDeleteModal(userId, userName) {
        deleteUserId = userId;
        document.getElementById('deleteUserName').innerText = userName;
        document.getElementById('deleteModal').style.display = 'flex';
    }
    function closeDeleteModal() {
        document.getElementById('deleteModal').style.display = 'none';
        deleteUserId = null;
    }

    // Close modals on outside click
    window.onclick = function(event) {
        const resetModal = document.getElementById('resetModal');
        const deleteModal = document.getElementById('deleteModal');
        if (event.target === resetModal) closeResetModal();
        if (event.target === deleteModal) closeDeleteModal();
    }

    // ----- API CALLS -----
    document.getElementById('confirmResetBtn').addEventListener('click', async function() {
        const userId = document.getElementById('resetUserId').value;
        const newPassword = document.getElementById('newPassword').value;
        
        if (!newPassword || newPassword.length < 6) {
            return showToast('Password must be at least 6 characters.', 'error');
        }

        const originalText = this.innerText;
        this.innerHTML = '<i class="ph ph-spinner ph-spin"></i> Saving...';
        this.disabled = true;

        try {
            const res = await fetch(`/admin/users/${userId}/reset-password`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ newPassword })
            });
            const result = await res.json();
            
            if (res.ok) {
                showToast('<%= t.common.success %>', 'success');
                closeResetModal();
            } else {
                showToast(result.message || '<%= t.common.error %>', 'error');
            }
        } catch (err) {
            console.error(err);
            showToast('<%= t.common.error %>', 'error');
        } finally {
            this.innerText = originalText;
            this.disabled = false;
        }
    });

    document.getElementById('confirmDeleteBtn').addEventListener('click', async function() {
        if (!deleteUserId) return;
        
        const originalText = this.innerText;
        this.innerHTML = '<i class="ph ph-spinner ph-spin"></i> Deleting...';
        this.disabled = true;

        try {
            const res = await fetch(`/admin/users/${deleteUserId}`, { method: 'DELETE' });
            const result = await res.json();
            
            if (res.ok) {
                showToast('<%= t.common.success %>', 'success');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                showToast(result.message || '<%= t.common.error %>', 'error');
            }
        } catch (err) {
            console.error(err);
            showToast('<%= t.common.error %>', 'error');
        } finally {
            closeDeleteModal();
            this.innerText = originalText;
            this.disabled = false;
        }
    });

    // ----- CREATE USER NATIVE LOGIC -----
    document.getElementById('createUserForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        const submitBtn = this.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        
        submitBtn.innerHTML = '<i class="ph ph-spinner ph-spin"></i> <%= t.common.processing %>';
        submitBtn.disabled = true;
        
        try {
            const response = await fetch('/admin/users', { method: 'POST', body: formData });
            const result = await response.json();
            
            if (response.ok) {
                showToast('<%= t.common.success %>', 'success');
                setTimeout(() => window.location.reload(), 800);
            } else {
                showToast(result.message || '<%= t.common.error %>', 'error');
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        } catch (err) {
            showToast('<%= t.common.error %>', 'error');
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
        }
    });
</script>

<%- include('partials/admin-footer', { page: 'users' }) %>