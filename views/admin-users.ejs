<%- include('partials/admin-header', { title: t.adminUsers.title, page: 'users' }) %>

<style>
    .toolbar { margin-bottom: 20px; }
    
    .search-bar {
        display: flex;
        align-items: center;
        background: var(--surface-dark);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
        padding: 10px 16px;
        gap: 12px;
        transition: all var(--transition-fast);
        max-width: 450px;
    }
    .search-bar:focus-within {
        border-color: var(--primary);
        box-shadow: 0 0 0 4px rgba(59,130,246,0.15);
    }
    .search-bar i { color: var(--text-muted); font-size: 1.2rem; }
    .search-bar:focus-within i { color: var(--primary); }
    .search-bar input {
        border: none; background: transparent; color: var(--text-main);
        outline: none; width: 100%; font-size: 0.95rem; font-family: inherit;
    }
    .search-bar input::placeholder { color: var(--text-muted); }

    .users-layout {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
        align-items: start;
        margin-top: 20px;
    }
    @media (max-width: 992px) {
        .users-layout { grid-template-columns: 1fr; }
    }

    /* ===== Unified Responsive Card Grid (Matches Orders Page) ===== */
    .users-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 1.25rem;
    }

    .user-card {
        background: var(--surface-dark);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        box-shadow: var(--shadow-sm);
        transition: transform var(--transition-fast), box-shadow var(--transition-fast), border-color var(--transition-fast);
    }
    .user-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }
    .user-card.highlight {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(59,130,246,0.2);
    }

    .user-card-top {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .user-card-profile {
        display: flex;
        align-items: center;
        gap: 10px;
        max-width: 70%;
    }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
        background: var(--surface-light);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: bold;
        color: var(--text-muted);
        border: 1px solid var(--glass-border);
    }
    .user-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .user-card-name {
        font-weight: 600;
        color: var(--text-main);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .user-card-bottom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: var(--text-muted);
        font-size: 0.85rem;
    }

    .user-card-pharmacy {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 60%;
    }

    .user-action-btns {
        display: flex;
        gap: 8px;
    }

    .user-icon-btn {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid var(--glass-border);
        background: transparent;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all var(--transition-fast);
    }
    .user-icon-btn.eye:hover {
        color: var(--primary);
        background: rgba(59,130,246,0.1);
        border-color: var(--primary);
    }
    .user-icon-btn.delete:hover {
        color: white;
        background: var(--danger);
        border-color: var(--danger);
    }

    /* ===== Create User Form ===== */
    .create-user .form-group input,
    .create-user .form-group select,
    .create-user .form-group .file-input {
        width: 100%;
        padding: 12px 14px;
        border-radius: 8px;
        border: 1px solid var(--glass-border);
        background: var(--surface-light);
        color: var(--text-main);
        font-size: 0.95rem;
        transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    }
    .create-user .form-group input:focus,
    .create-user .form-group select:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(59,130,246,0.2);
    }
    .create-user .form-group label {
        display: block;
        margin-bottom: 6px;
        font-weight: 500;
        color: var(--text-main);
        font-size: 0.85rem;
    }
    .create-user .btn-primary { width: 100%; padding: 14px; font-size: 1rem; margin-top: 10px; }

    /* ===== Detail Modal Grid ===== */
    #userDetailModal .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        font-size: 0.95rem;
        margin-bottom: 1rem;
        background: var(--surface-light);
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid var(--glass-border);
    }
    @media (max-width: 480px) {
        #userDetailModal .detail-grid { grid-template-columns: 1fr; }
    }
    #userDetailModal .detail-grid p { margin: 0; color: var(--text-main); }
    #userDetailModal .detail-grid strong {
        display: block;
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>

<div class="toolbar">
    <div class="search-bar">
        <i class="ph ph-magnifying-glass"></i>
        <input type="text" id="searchInput" placeholder="<%= t.adminUsers.searchPlaceholder %>">
    </div>
</div>

<div class="users-layout">
    <section class="users-grid" id="usersGrid">
        <% users.forEach((user) => { %>
        <div class="user-card" id="user-card-<%= user._id %>" data-name="<%= user.name.toLowerCase() %>" data-pharmacy="<%= user.pharmacy ? user.pharmacy.toLowerCase() : '' %>" data-email="<%= user.email.toLowerCase() %>" data-role="<%= user.role.toLowerCase() %>">
            
            <div class="user-card-top">
                <div class="user-card-profile">
                    <div class="user-avatar">
                        <% if(user.imageURL) { %>
                            <img src="<%= user.imageURL %>" alt="<%= user.name %>">
                        <% } else { %>
                            <%= user.name[0].toUpperCase() %>
                        <% } %>
                    </div>
                    <span class="user-card-name"><%= user.name %></span>
                </div>
                <span class="badge <%= user.role === 'admin' ? 'approved' : 'pending' %>">
                    <%= user.role === 'admin' ? t.common.admin : t.adminRequests.user %>
                </span>
            </div>

            <div class="user-card-bottom">
                <span class="user-card-pharmacy"><%= user.pharmacy %></span>
                
                <div class="user-action-btns">
                    <button class="user-icon-btn eye" data-user="<%= encodeURIComponent(JSON.stringify(user)) %>" onclick="openUserDetail(this)" title="<%= t.common.viewDetails %>">
                        <i class="ph ph-eye"></i>
                    </button>
                    
                    <% if (user.email !== 'suhrab@gmail.com') { %>
                        <button class="user-icon-btn delete" onclick="openDeleteModal('<%= user._id%>')" title="<%= t.common.delete %>">
                            <i class="ph ph-trash"></i>
                        </button>
                    <% } else { %>
                        <span class="badge approved" style="background: var(--surface-light); color: var(--text-muted); font-size:0.7rem;">
                            <i class="ph ph-lock-key"></i> <%= t.common.admin %>
                        </span>
                    <% } %>
                </div>
            </div>

        </div>
        <% }) %>
    </section>

    <section class="card create-user" style="margin: 0;">
        <div class="card-header" style="margin-bottom: 15px; padding-bottom: 15px; border-bottom: 1px solid var(--glass-border);">
            <h2 style="margin: 0;"><%= t.adminUsers.addNew %></h2>
        </div>
        <form id="createUserForm" enctype="multipart/form-data" style="display: flex; flex-direction: column; gap: 15px;">
            <div class="form-group">
                <label><%= t.common.name %></label>
                <input type="text" name="name" required>
            </div>
            <div class="form-group">
                <label><%= t.auth.pharmacyName %></label>
                <input type="text" name="pharmacy" required>
            </div>
            <div class="form-group">
                <label><%= t.common.email %></label>
                <input type="email" name="email" required>
            </div>
            <div class="form-group">
                <label><%= t.auth.password %></label>
                <input type="password" name="password" required>
            </div>
            <div class="form-group">
                <label><%= t.common.role %></label>
                <select name="role">
                    <option value="user"><%= t.adminRequests.user %></option>
                    <option value="admin"><%= t.common.admin %></option>
                </select>
            </div>
            <div class="form-group">
                <label><%= t.common.image %></label>
                <input type="file" name="imageURL" accept="image/*" class="file-input">
            </div>
            <button type="submit" class="btn-primary"><%= t.adminDashboard.createUser %></button>
        </form>
    </section>
</div>

<div id="toast-container"></div>

<div id="userDetailModal" class="custom-backdrop" style="display: none;">
    <div class="modal-content" style="display: block; opacity: 1; max-width: 480px; width: 95%; padding: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h3 style="margin:0;"><%= t.common.viewDetails %></h3>
            <button type="button" onclick="closeUserDetail()" style="background: transparent; border: none; color: var(--text-muted); font-size: 1.5rem; cursor: pointer; line-height: 1;">&times;</button>
        </div>
        <div id="userDetailContent"></div>
    </div>
</div>

<div id="deleteModal" class="custom-backdrop" style="display: none;">
    <div class="modal-content confirmation-box" style="display: block; opacity: 1;">
        <div class="icon-box danger large" style="margin: 0 auto 15px;">
            <i class="ph ph-trash"></i>
        </div>
        <h3 style="text-align: center;"><%= t.adminUsers.deleteModalTitle %></h3>
        <p style="text-align: center; color: var(--text-muted);"><%= t.adminUsers.deleteWarning %></p>
        <div class="modal-actions" style="margin-top: 1.5rem; display: flex; gap: 10px;">
            <button class="btn-cancel" onclick="closeDeleteModal()" style="flex: 1;"><%= t.common.cancel %></button>
            <button class="btn-delete" id="confirmDeleteBtn" style="flex: 1;"><%= t.common.delete %></button>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const deleteModal = document.getElementById('deleteModal');
        const detailModal = document.getElementById('userDetailModal');
        const toastContainer = document.getElementById('toast-container');
        
        if(deleteModal) document.body.appendChild(deleteModal);
        if(detailModal) document.body.appendChild(detailModal);
        if(toastContainer) document.body.appendChild(toastContainer);
    });

    function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        const icon = type === 'success' ? '<i class="ph ph-check-circle"></i>' : '<i class="ph ph-warning-circle"></i>';
        toast.className = `toast ${type}`; 
        toast.innerHTML = `${icon} <span>${message}</span>`;
        container.appendChild(toast);

        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-20px)';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    // ----- SEARCH WITH HIGHLIGHT -----
    const searchInput = document.getElementById('searchInput');
    const userCards = document.querySelectorAll('.user-card');

    searchInput.addEventListener('input', function() {
        const term = this.value.toLowerCase().trim();

        userCards.forEach(card => {
            const name = card.dataset.name || '';
            const pharmacy = card.dataset.pharmacy || '';
            const email = card.dataset.email || '';
            const role = card.dataset.role || '';

            const matches = term === '' || name.includes(term) || pharmacy.includes(term) || email.includes(term) || role.includes(term);

            if (matches) {
                card.style.display = 'flex';
                if(term !== '') card.classList.add('highlight');
                else card.classList.remove('highlight');
            } else {
                card.style.display = 'none';
                card.classList.remove('highlight');
            }
        });
    });

    // ----- USER DETAIL MODAL -----
    function openUserDetail(btn) {
        try {
            const encodedData = btn.getAttribute('data-user');
            const user = JSON.parse(decodeURIComponent(encodedData));
            const joinedDate = user.createdAt ? new Date(user.createdAt).toLocaleDateString() : 'N/A';
            const roleBadge = user.role === 'admin' ? 'approved' : 'pending';
            const displayRole = user.role === 'admin' ? '<%= t.common.admin %>' : '<%= t.adminRequests.user %>';

            const content = document.getElementById('userDetailContent');
            content.innerHTML = `
                ${user.imageURL ? `<img src="${user.imageURL}" alt="${user.name}" style="width:100px; height:100px; border-radius:50%; object-fit:cover; margin:0 auto 1.5rem auto; display:block; border:1px solid var(--glass-border);" />` : ''}
                <div class="detail-grid">
                    <p><strong><%= t.common.name %></strong> ${user.name || 'N/A'}</p>
                    <p><strong><%= t.common.pharmacy %></strong> ${user.pharmacy || 'N/A'}</p>
                    <p><strong><%= t.common.email %></strong> <a href="mailto:${user.email}" style="color: var(--primary);">${user.email || 'N/A'}</a></p>
                    <p><strong><%= t.common.role %></strong> <span class="badge ${roleBadge}">${displayRole}</span></p>
                    <p><strong><%= t.adminUsers.joined %></strong> ${joinedDate}</p>
                    <p><strong>ID</strong> <code style="font-size:0.75rem; color: var(--text-muted);">${user._id}</code></p>
                </div>
            `;
            
            document.getElementById('userDetailModal').style.display = 'flex';
        } catch(err) {
            console.error("Error reading user data", err);
        }
    }

    function closeUserDetail() {
        document.getElementById('userDetailModal').style.display = 'none';
    }
    
    document.getElementById('userDetailModal').addEventListener('click', function(e) {
        if (e.target === this) closeUserDetail();
    });

    // ----- BULLETPROOF DELETE NATIVE LOGIC -----
    let userIdToDelete = null;

    window.openDeleteModal = function(id) {
        userIdToDelete = id;
        document.getElementById('deleteModal').style.display = 'flex';
    }

    window.closeDeleteModal = function() {
        userIdToDelete = null;
        document.getElementById('deleteModal').style.display = 'none';
    }

    document.getElementById('deleteModal').addEventListener('click', function(e) {
        if (e.target === this) closeDeleteModal();
    });

    document.getElementById('confirmDeleteBtn').addEventListener('click', async function() {
        if (!userIdToDelete) return;
        
        const originalText = this.innerText;
        this.innerText = '...';
        this.disabled = true;

        try {
            const response = await fetch(`/admin/users/${userIdToDelete}`, { method: 'DELETE' });
            const result = await response.json();

            if (response.ok) {
                const card = document.getElementById(`user-card-${userIdToDelete}`);
                if (card) card.remove();
                
                showToast('<%= t.common.success %>', 'success');
            } else {
                showToast(result.message || '<%= t.common.error %>', 'error');
            }
        } catch (err) {
            console.error(err);
            showToast('<%= t.common.error %>', 'error');
        } finally {
            closeDeleteModal();
            this.innerText = originalText;
            this.disabled = false;
        }
    });

    // ----- CREATE USER NATIVE LOGIC -----
    document.getElementById('createUserForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const formData = new FormData(this);
        const submitBtn = this.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerText;
        
        submitBtn.innerHTML = '<i class="ph ph-spinner ph-spin"></i> <%= t.common.processing %>';
        submitBtn.disabled = true;
        
        try {
            const response = await fetch('/admin/users', { method: 'POST', body: formData });
            const result = await response.json();
            
            if (response.ok) {
                showToast('<%= t.common.success %>', 'success');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                showToast(result.message || '<%= t.common.error %>', 'error');
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            }
        } catch (err) {
            showToast('<%= t.common.error %>', 'error');
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false;
        }
    });
</script>

<%- include('partials/admin-footer', { page: 'users' }) %>