<%- include('../partials/user-header', { title: t.settings.title, page: 'settings' }) %>

<div class="card settings-card settings-card--compact">
  <!-- Header -->
  <div class="settings-header">
    <h2><i class="ph ph-gear"></i> <%= t.settings.title %></h2>
  </div>

  <!-- Profile row (compact) -->
  <div class="profile-row-compact">
    <div class="avatar avatar-md">
      <% if (user && user.imageURL) { %>
        <img src="<%= user.imageURL %>" alt="Profile" class="avatar-img">
      <% } else { %>
        <span class="avatar-letter"><%= (typeof userName !== 'undefined' && userName) ? userName[0].toUpperCase() : 'U' %></span>
      <% } %>
    </div>
    <div class="profile-info-compact">
      <h3><%= typeof userName !== 'undefined' ? userName : t.adminRequests.user %></h3>
      <p><%= (user && user.pharmacy) ? user.pharmacy : t.common.pharmacy %></p>
    </div>
  </div>

  <!-- Settings in a 2‑column grid (desktop) -->
  <div class="settings-grid">
    <!-- Appearance -->
    <div class="settings-item">
      <div class="settings-item-text">
        <h4><i class="ph ph-paint-brush"></i> <%= t.settings.appearance %></h4>
        <p><%= t.settings.appearanceDesc %></p>
      </div>
      <button id="themeToggle" class="btn-icon theme-toggle-btn-sm" aria-label="Toggle theme">
        <i class="ph ph-moon" id="themeIcon"></i>
      </button>
    </div>

    <!-- Language -->
    <div class="settings-item">
      <div class="settings-item-text">
        <h4><i class="ph ph-globe"></i> <%= t.settings.language %></h4>
        <p><%= t.settings.languageDesc %></p>
      </div>
      <div class="lang-group">
        <a href="/lang/en" class="lang-btn-sm <%= lang === 'en' ? 'active' : '' %>">EN</a>
        <a href="/lang/fa" class="lang-btn-sm <%= lang === 'fa' ? 'active' : '' %>">فا</a>
        <a href="/lang/ps" class="lang-btn-sm <%= lang === 'ps' ? 'active' : '' %>">پښ</a>
      </div>
    </div>
  </div>

  <!-- Logout (full width, compact) -->
  <div class="logout-row-compact">
    <a href="/user/logout" class="btn-text logout-btn">
      <i class="ph ph-sign-out"></i> <%= t.settings.logout %>
    </a>
  </div>
</div>

<div class="mobile-spacer" style="height: 100px"></div>

<%- include('../partials/mobile-nav', { page: 'settings' }) %>
<%- include('../partials/footer') %>

<script>
  (function() {
    const themeToggle = document.getElementById('themeToggle');
    const themeIcon = document.getElementById('themeIcon');
    
    function setTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
      if (themeIcon) {
        themeIcon.className = theme === 'dark' ? 'ph ph-moon' : 'ph ph-sun';
      }
    }
    
    function getPreferredTheme() {
      const stored = localStorage.getItem('theme');
      if (stored) return stored;
      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    
    if (themeToggle) {
      themeToggle.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme') || 'dark';
        const newTheme = current === 'dark' ? 'light' : 'dark';
        setTheme(newTheme);
      });
    }
    
    const initialTheme = getPreferredTheme();
    setTheme(initialTheme);
  })();
</script>