<%- include('../partials/user-header', { title: t.userOrders.myOrders, page: 'orders' }) %>

<style>
  /* ==============================
     ORDERS LIST – CARD BASED (MOBILE FIRST)
     ============================== */
  .orders-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 0.5rem;
    margin-top: 1rem;
  }

  .order-card {
    background: var(--surface-dark);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .order-card:hover {
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
  }

  .order-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .order-info h3 {
    margin: 0;
    font-size: 1.1rem;
    color: var(--text-main);
  }

  .order-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 0.35rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .order-status {
    flex-shrink: 0;
  }

  .order-details-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    background: var(--bg-dark);
    padding: 0.85rem;
    border-radius: 8px;
    border: 1px solid var(--glass-border);
  }

  .detail-box {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .detail-label {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .detail-value {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .order-actions {
    display: flex;
    justify-content: flex-end;
    padding-top: 0.5rem;
    border-top: 1px solid var(--glass-border);
  }

  .btn-cancel {
    background: rgba(239, 68, 68, 0.1);
    color: var(--danger);
    border: 1px solid rgba(239, 68, 68, 0.2);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: all 0.2s ease;
  }

  .btn-cancel:hover {
    background: var(--danger);
    color: #fff;
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--surface-dark);
    border-radius: 12px;
    border: 1px dashed var(--glass-border);
  }

  .empty-state i {
    font-size: 3rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .empty-state p {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  /* Two columns on tablets/desktops */
  @media (min-width: 768px) {
    .orders-container {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

<div class="orders-container">
  <% if (orders && orders.length > 0) { %>
    <% orders.forEach(order => { 
      const date = new Date(order.createdAt).toLocaleDateString(lang === 'en' ? 'en-US' : 'fa-IR', { 
        year: 'numeric', 
        month: 'short', 
        day: 'numeric' 
      });
      
      let statusClass = (order.status || 'Pending').toLowerCase();
      if (statusClass === 'rejected') statusClass = 'cancelled';
      const badgeClass = ['pending', 'approved', 'cancelled'].includes(statusClass) ? statusClass : 'pending';
    %>
      <div class="order-card">
        
        <div class="order-header">
          <div class="order-info">
            <h3><%= order.medicineId ? order.medicineId.name : t.common.unknownMedicine || 'Unknown Medicine' %></h3>
            <div class="order-date">
              <i class="ph ph-calendar-blank"></i> <%= date %>
            </div>
          </div>
          <div class="order-status">
            <span class="badge <%= badgeClass %>"><%= order.status %></span>
          </div>
        </div>

        <div class="order-details-grid">
          <div class="detail-box">
            <span class="detail-label"><%= t.userOrders.thPrice || 'Unit Price' %></span>
            <span class="detail-value">
              <i class="ph ph-money"></i> 
              ؋ <%= order.price ? order.price.toLocaleString() : '0' %>
            </span>
          </div>
          <div class="detail-box">
            <span class="detail-label"><%= t.userOrders.thQty || 'Quantity' %></span>
            <span class="detail-value">
              <i class="ph ph-cube"></i> 
              <%= order.quantity %>
            </span>
          </div>
          <div class="detail-box" style="grid-column: 1 / -1;">
            <span class="detail-label"><%= t.userOrders.thTotal || 'Total Price' %></span>
            <span class="detail-value" style="color: var(--primary); font-size: 1.1rem;">
              ؋ <%= order.totalPrice ? order.totalPrice.toLocaleString() : '0' %>
            </span>
          </div>
        </div>

        <% if (order.status === 'Pending') { %>
          <div class="order-actions">
            <form action="/user/order/cancel" method="POST" onsubmit="return confirm('<%= t.userOrders.confirmCancel %>');" style="margin: 0;">
              <input type="hidden" name="orderId" value="<%= order._id %>">
              <button type="submit" class="btn-cancel">
                <i class="ph ph-x-circle"></i> <%= t.userOrders.cancelOrder %>
              </button>
            </form>
          </div>
        <% } %>

      </div>
    <% }) %>
  <% } else { %>
    <div style="grid-column: 1 / -1;">
      <div class="empty-state">
        <i class="ph ph-package"></i>
        <p><%= t.userOrders.emptyState %></p>
        <a href="/user/dashboard" class="btn-primary" style="display: inline-block; text-decoration: none;">
          <%= t.userOrders.goToMarket || 'Go to Market' %>
        </a>
      </div>
    </div>
  <% } %>
</div>

<div class="mobile-spacer" style="height: 100px;"></div>

<%- include('../partials/mobile-nav', { page: 'orders' }) %>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Mobile navigation highlighting
    const currentPath = window.location.pathname;
    document.querySelectorAll('.mobile-bottom-nav a').forEach(link => {
      if (link.getAttribute('href') === currentPath) {
        link.classList.add('active');
      }
    });
  });
</script>

<%- include('../partials/footer') %>