<%- include('../partials/user-header', { title: t.userRequest.pageTitle, page: 'request' }) %>

<style>
  /* ===== REQUEST FORM – Unified with Global Theme ===== */

  .request-form-card {
    background: var(--surface-dark);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 1.75rem 1.5rem;
    box-shadow: var(--shadow-sm);
    margin-bottom: 2rem;
  }

  .request-form-header h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--text-main);
    margin-bottom: 0.25rem;
  }

  .request-form-sub {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  /* Cards container */
  .cards-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  /* Individual request card – matches order‑card style */
  .request-card-item {
    background: var(--surface-dark);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    position: relative;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--transition-fast), border-color var(--transition-fast);
  }

  .request-card-item:hover {
    box-shadow: var(--shadow-md);
  }

  /* Card number badge */
  .card-number {
    position: absolute;
    top: 0.65rem;
    right: 0.75rem;
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--text-muted);
    background: var(--surface-light);
    padding: 0.2rem 0.65rem;
    border-radius: 20px;
    border: 1px solid var(--glass-border);
  }

  html[lang="ps"] .card-number {
    right: auto;
    left: 0.75rem;
  }

  html[lang="fa"] .card-number {
    right: auto;
    left: 0.75rem;
  }

  /* Field layout inside card */
  .card-fields {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .card-field {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .card-field label {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .card-field input,
  .card-field textarea {
    width: 100%;
    padding: 0.65rem 0.8rem;
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: inherit;
    background: var(--surface-dark);
    color: var(--text-main);
    outline: none;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    resize: vertical;
  }

  .card-field input::placeholder,
  .card-field textarea::placeholder {
    color: var(--text-muted);
    opacity: 0.7;
  }

  .card-field input:focus,
  .card-field textarea:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
  }

  /* Delete button inside card */
  .card-delete {
    align-self: flex-end;
    background: transparent;
    border: 1px solid var(--glass-border);
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.4rem 0.8rem;
    border-radius: 8px;
    transition: all var(--transition-fast);
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.85rem;
  }

  .card-delete:hover {
    background: rgba(239,68,68,0.1);
    color: var(--danger);
    border-color: var(--danger);
  }

  /* Validation highlight */
  .request-card-item.invalid {
    border-color: #fca5a5;
    box-shadow: 0 0 0 3px rgba(239,68,68,0.1);
  }

  /* Form actions row */
  .form-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  /* Add row button – same as btn-text */
  .add-row-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 500;
    color: var(--text-muted);
    background: transparent;
    border: 1px solid var(--glass-border);
    cursor: pointer;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .add-row-btn:hover {
    background: rgba(255,255,255,0.05);
    color: var(--text-main);
  }

  /* Submit button – matches btn-primary */
  .btn-submit {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--primary);
    color: white;
    border: none;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    font-family: inherit;
    cursor: pointer;
    transition: background var(--transition-fast), transform var(--transition-fast);
  }

  .btn-submit:hover {
    background: #2563eb;
    transform: translateY(-1px);
  }

  .btn-submit:active {
    transform: translateY(0);
  }

  /* Responsive tweaks */
  @media (max-width: 480px) {
    .request-form-card {
      padding: 1.25rem 1rem;
    }
    .form-actions {
      flex-direction: column;
      align-items: stretch;
    }
    .btn-submit, .add-row-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<section class="request-form-card">
  <div class="request-form-header">
    <h2><%= t.userRequest.detailsTitle %></h2>
    <p class="request-form-sub"><%= t.userRequest.subtitle %> (Multiple allowed)</p>
  </div>

  <!-- Container for dynamically added cards -->
  <div id="cardsContainer" class="cards-container">
    <!-- Cards are inserted by JavaScript -->
  </div>

  <div class="form-actions">
    <button type="button" class="add-row-btn" onclick="addCard()">
      <i class="ph ph-plus-circle"></i> Add Row
    </button>
    <button type="button" class="btn-submit" onclick="submitSheet()">
      <i class="ph ph-paper-plane-right"></i> <%= t.userRequest.submitBtn %>
    </button>
  </div>
</section>

<div class="mobile-spacer" style="height: 100px"></div>
</main>
</div>

<%- include('../partials/mobile-nav', { page: 'request' }) %>

<script>
  const currentPath = window.location.pathname;
  document.querySelectorAll('.mobile-bottom-nav a').forEach((link) => {
    if (link.getAttribute('href') === currentPath) link.classList.add('active');
  });

  const cardsContainer = document.getElementById('cardsContainer');
  let cardCount = 0;

  function addCard() {
    cardCount++;
    const card = document.createElement('div');
    card.className = 'request-card-item';
    card.dataset.cardIndex = cardCount;

    card.innerHTML = `
      <div class="card-number">${cardCount}</div>
      <div class="card-fields">
        <div class="card-field">
          <label><%= t.userRequest.medName %> *</label>
          <input type="text" name="medicineName" placeholder="e.g. Panadol Extra" required>
        </div>
        <div class="card-field">
          <label><%= t.userRequest.companyName %> *</label>
          <input type="text" name="companyName" placeholder="e.g. GSK" required>
        </div>
        <div class="card-field" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
          <div class="card-field">
            <label><%= t.common.quantity %> *</label>
            <input type="number" name="quantity" placeholder="e.g. 50" min="1" required>
          </div>
          <div class="card-field">
            <label><%= t.userRequest.shapeDose %> *</label>
            <input type="text" name="shapeAndDose" placeholder="Tablet 500mg" required>
          </div>
        </div>
        <div class="card-field">
          <label><%= t.userRequest.tradeName %></label>
          <input type="text" name="tradeName" placeholder="Brand name">
        </div>
        <div class="card-field">
          <label><%= t.userRequest.scientificName %></label>
          <input type="text" name="scientificName" placeholder="Generic name">
        </div>
        <div class="card-field">
          <label><%= t.userRequest.description %></label>
          <input type="text" name="description" placeholder="Optional notes...">
        </div>
      </div>
      <button type="button" class="card-delete" onclick="deleteCard(this)">
        <i class="ph ph-trash"></i> Remove
      </button>
    `;

    cardsContainer.appendChild(card);
  }

  function deleteCard(btn) {
    const card = btn.closest('.request-card-item');
    if (!card) return;
    card.style.opacity = '0';
    card.style.transform = 'scale(0.95)';
    card.style.transition = 'all 0.2s';
    setTimeout(() => {
      card.remove();
      updateCardNumbers();
    }, 200);
  }

  function updateCardNumbers() {
    const cards = cardsContainer.querySelectorAll('.request-card-item');
    cards.forEach((card, index) => {
      card.querySelector('.card-number').textContent = index + 1;
    });
    cardCount = cards.length;
  }

  // Initialize with 3 cards
  addCard(); addCard(); addCard();

  async function submitSheet() {
    const cards = document.querySelectorAll('.request-card-item');
    const requestsData = [];
    let isValid = true;

    cards.forEach(card => {
      const medName = card.querySelector('[name="medicineName"]').value.trim();
      const company = card.querySelector('[name="companyName"]').value.trim();
      const qty = card.querySelector('[name="quantity"]').value;
      const shape = card.querySelector('[name="shapeAndDose"]').value.trim();

      if (medName) {
        if (!company || !qty || !shape) {
          isValid = false;
          card.classList.add('invalid');
        } else {
          card.classList.remove('invalid');
          requestsData.push({
            medicineName: medName,
            companyName: company,
            quantity: qty,
            shapeAndDose: shape,
            tradeName: card.querySelector('[name="tradeName"]').value.trim(),
            scientificName: card.querySelector('[name="scientificName"]').value.trim(),
            description: card.querySelector('[name="description"]').value.trim(),
          });
        }
      } else {
        card.classList.remove('invalid');
      }
    });

    if (!isValid) {
      return alert('Please fill all required (*) fields in your rows.');
    }

    if (requestsData.length === 0) {
      return alert('Please enter at least one medicine request.');
    }

    const btn = document.querySelector('.btn-submit');
    const originalHTML = btn.innerHTML;
    btn.innerHTML = `<i class="ph ph-spinner ph-spin"></i> <%= t.userRequest.sending %>`;
    btn.disabled = true;

    try {
      const res = await fetch('/user/request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ requests: requestsData }),
      });

      if (res.ok) {
        btn.style.backgroundColor = 'var(--success)';
        btn.innerHTML = `<i class="ph ph-check"></i> <%= t.userRequest.sentSuccess %>`;
        setTimeout(() => (window.location.href = '/user/my-requests'), 1000);
      } else {
        alert('Error sending request');
        btn.innerHTML = originalHTML;
        btn.disabled = false;
      }
    } catch (err) {
      alert('Network error');
      btn.innerHTML = originalHTML;
      btn.disabled = false;
    }
  }
</script>

<%- include('../partials/footer') %>