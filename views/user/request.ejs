<%- include('../partials/user-header', { title: t.userRequest.pageTitle, page: 'request' }) %>

<style>
  /* ===== REQUEST FORM – ULTRA COMPACT & FLOATING LABELS ===== */
  .request-form-card {
    background: transparent; 
    padding: 0.25rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .request-form-header {
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .request-form-header h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 0.25rem;
    letter-spacing: -0.5px;
  }

  .request-form-sub {
    color: var(--text-muted);
    font-size: 0.85rem;
  }

  /* Cards container */
  .cards-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  /* Individual request card - Reduced padding heavily */
  .request-card-item {
    background: var(--surface-dark);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 1rem; /* Reduced from 1.5rem */
    display: flex;
    flex-direction: column;
    gap: 0.85rem; /* Reduced from 1.25rem */
    box-shadow: var(--shadow-sm);
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .request-card-item:hover {
    box-shadow: var(--shadow-md);
    border-color: rgba(59, 130, 246, 0.3);
  }

  /* Card Header */
  .card-top-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--glass-border);
    padding-bottom: 0.5rem;
  }

  .card-number {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--text-main);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .card-number i {
    color: var(--primary);
    font-size: 1.1rem;
  }

  .card-delete-icon {
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    width: 30px;
    height: 30px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    transition: all var(--transition-fast);
  }

  .card-delete-icon:hover {
    background: rgba(239, 68, 68, 0.1);
    color: var(--danger);
  }

  /* Field Grid - Reduced gaps */
  .card-fields {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem; /* Tighter gap */
  }

  @media (min-width: 600px) {
    .card-fields {
      grid-template-columns: repeat(2, 1fr);
    }
    .field-full {
      grid-column: 1 / -1;
    }
  }

  /* ==============================
     FLOATING LABELS UI
     ============================== */
  .floating-field {
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .floating-field input,
  .floating-field textarea {
    width: 100%;
    /* Create space at the top for the floating label */
    padding: 1.15rem 0.75rem 0.35rem 0.75rem; 
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    font-size: 0.95rem;
    font-family: inherit;
    background: var(--bg-dark);
    color: var(--text-main);
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .floating-field textarea {
    resize: vertical;
    padding-top: 1.25rem;
  }

  .floating-field input:focus,
  .floating-field textarea:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.15);
  }

  .floating-field label {
    position: absolute;
    /* Center it perfectly like a standard placeholder */
    top: 50%;
    left: 0.75rem;
    transform: translateY(-50%);
    font-size: 0.9rem;
    color: var(--text-muted);
    pointer-events: none;
    transition: all 0.2s ease;
  }

  .floating-field textarea ~ label {
    top: 1rem;
    transform: none;
  }

  /* When input is focused, OR when the input has text (not showing the blank placeholder) -> Float the label */
  .floating-field input:focus ~ label,
  .floating-field input:not(:placeholder-shown) ~ label,
  .floating-field textarea:focus ~ label,
  .floating-field textarea:not(:placeholder-shown) ~ label {
    top: 0.4rem;
    transform: translateY(0);
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--primary);
  }

  .floating-field input:not(:focus):not(:placeholder-shown) ~ label,
  .floating-field textarea:not(:focus):not(:placeholder-shown) ~ label {
    color: var(--text-muted); /* Keep floating but revert color if not focused */
  }

  .floating-field label span.required {
    color: var(--danger);
  }

  /* Validation highlight */
  .request-card-item.invalid {
    border-color: var(--danger);
    box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.1);
  }

  /* Form actions */
  .form-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .add-row-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 600;
    color: var(--primary);
    background: rgba(59, 130, 246, 0.1);
    border: 1px dashed rgba(59, 130, 246, 0.4);
    cursor: pointer;
    padding: 0.75rem 1.25rem;
    border-radius: 10px;
    font-size: 0.9rem;
    transition: all 0.2s ease;
  }

  .add-row-btn:hover {
    background: rgba(59, 130, 246, 0.15);
    border-style: solid;
  }

  .btn-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    background: var(--primary);
    color: white;
    border: none;
    padding: 0.75rem 1.75rem;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-submit:hover {
    background: #2563eb;
  }

  @media (max-width: 600px) {
    .form-actions {
      flex-direction: column-reverse;
      align-items: stretch;
    }
    .btn-submit, .add-row-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<section class="request-form-card">
  <div class="request-form-header">
    <h2><i class="ph ph-hand-waving"></i> <%= t.userRequest.detailsTitle %></h2>
    <p class="request-form-sub"><%= t.userRequest.subtitle %></p>
  </div>

  <div id="cardsContainer" class="cards-container">
    </div>

  <div class="form-actions">
    <button type="button" class="add-row-btn" onclick="addCard()">
      <i class="ph ph-plus"></i> Add Another Item
    </button>
    <button type="button" class="btn-submit" onclick="submitSheet()">
      <i class="ph ph-paper-plane-right"></i> <%= t.userRequest.submitBtn %>
    </button>
  </div>
</section>

<div class="mobile-spacer" style="height: 100px"></div>
</main>
</div>

<%- include('../partials/mobile-nav', { page: 'request' }) %>

<script>
  // Mobile Nav Highlighting
  const currentPath = window.location.pathname;
  document.querySelectorAll('.mobile-bottom-nav a').forEach((link) => {
    if (link.getAttribute('href') === currentPath) link.classList.add('active');
  });

  const cardsContainer = document.getElementById('cardsContainer');
  let cardCount = 0;

  function addCard() {
    cardCount++;
    const card = document.createElement('div');
    card.className = 'request-card-item';
    
    // Dynamic HTML for the card - Notice placeholder=" " is required for the floating CSS trick to work
    card.innerHTML = `
      <div class="card-top-row">
        <div class="card-number">
          <i class="ph ph-prescription"></i> Item <span class="num-text">${cardCount}</span>
        </div>
        <button type="button" class="card-delete-icon" onclick="deleteCard(this)" title="Remove Item">
          <i class="ph ph-trash"></i>
        </button>
      </div>

      <div class="card-fields">
        <div class="floating-field">
          <input type="text" name="medicineName" placeholder=" " required>
          <label><%= t.userRequest.medName %> <span class="required">*</span></label>
        </div>

        <div class="floating-field">
          <input type="text" name="companyName" placeholder=" " required>
          <label><%= t.userRequest.companyName %> <span class="required">*</span></label>
        </div>

        <div class="floating-field">
          <input type="number" name="quantity" placeholder=" " min="1" required>
          <label><%= t.common.quantity %> <span class="required">*</span></label>
        </div>

        <div class="floating-field">
          <input type="text" name="shapeAndDose" placeholder=" " required>
          <label><%= t.userRequest.shapeDose %> <span class="required">*</span></label>
        </div>

        <div class="floating-field">
          <input type="text" name="tradeName" placeholder=" ">
          <label><%= t.userRequest.tradeName %></label>
        </div>

        <div class="floating-field">
          <input type="text" name="scientificName" placeholder=" ">
          <label><%= t.userRequest.scientificName %></label>
        </div>

        <div class="floating-field field-full">
          <textarea name="description" rows="2" placeholder=" "></textarea>
          <label><%= t.userRequest.description %></label>
        </div>
      </div>
    `;

    cardsContainer.appendChild(card);
  }

  function deleteCard(btn) {
    const card = btn.closest('.request-card-item');
    if (!card) return;
    
    // Animate out
    card.style.opacity = '0';
    card.style.transform = 'scale(0.95)';
    card.style.transition = 'all 0.2s ease';
    
    setTimeout(() => {
      card.remove();
      updateCardNumbers();
    }, 200);
  }

  function updateCardNumbers() {
    const cards = cardsContainer.querySelectorAll('.request-card-item');
    cards.forEach((card, index) => {
      card.querySelector('.num-text').textContent = index + 1;
    });
    cardCount = cards.length;
  }

  // INITIALIZE WITH ONLY 1 CARD
  addCard(); 

  async function submitSheet() {
    const cards = document.querySelectorAll('.request-card-item');
    const requestsData = [];
    let isValid = true;

    cards.forEach(card => {
      const medName = card.querySelector('[name="medicineName"]').value.trim();
      const company = card.querySelector('[name="companyName"]').value.trim();
      const qty = card.querySelector('[name="quantity"]').value;
      const shape = card.querySelector('[name="shapeAndDose"]').value.trim();

      if (medName || company || qty || shape) { // Check if user typed anything in this row
        if (!medName || !company || !qty || !shape) {
          isValid = false;
          card.classList.add('invalid');
        } else {
          card.classList.remove('invalid');
          requestsData.push({
            medicineName: medName,
            companyName: company,
            quantity: qty,
            shapeAndDose: shape,
            tradeName: card.querySelector('[name="tradeName"]').value.trim(),
            scientificName: card.querySelector('[name="scientificName"]').value.trim(),
            description: card.querySelector('[name="description"]').value.trim(),
          });
        }
      }
    });

    if (!isValid) {
      return alert('Please fill all required (*) fields in the highlighted items.');
    }

    if (requestsData.length === 0) {
      return alert('Please enter at least one medicine request.');
    }

    const btn = document.querySelector('.btn-submit');
    const originalHTML = btn.innerHTML;
    btn.innerHTML = `<i class="ph ph-spinner ph-spin"></i> <%= t.userRequest.sending %>`;
    btn.disabled = true;

    try {
      const res = await fetch('/user/request', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ requests: requestsData }),
      });

      if (res.ok) {
        btn.style.backgroundColor = 'var(--success)';
        btn.innerHTML = `<i class="ph ph-check-circle"></i> <%= t.userRequest.sentSuccess %>`;
        setTimeout(() => (window.location.href = '/user/my-requests'), 1000);
      } else {
        alert('Error sending request. Please try again.');
        btn.innerHTML = originalHTML;
        btn.disabled = false;
      }
    } catch (err) {
      console.error(err);
      alert('Network error. Check your connection.');
      btn.innerHTML = originalHTML;
      btn.disabled = false;
    }
  }
</script>

<%- include('../partials/footer') %>