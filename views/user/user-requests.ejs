<%- include('../partials/user-header', { title: t.userMyRequests.title, page: 'my-requests' }) %>

<!-- New Request Button (global style) -->
<div class="my-requests-action">
  <a href="/user/request" class="btn-primary">
    <i class="ph ph-plus"></i> <%= t.userMyRequests.btnNewRequest %>
  </a>
</div>

<!-- Requests List (responsive card grid) -->
<div class="requests-container">
  <% if (requests && requests.length > 0) { %>
    <% requests.forEach(req => { 
      const date = new Date(req.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
      // Map status to one of the global badge classes: pending, approved, cancelled
      let statusClass = (req.status || '').toLowerCase();
      if (statusClass === 'rejected') statusClass = 'cancelled';
      const badgeClass = ['pending', 'approved', 'cancelled'].includes(statusClass) ? statusClass : 'pending';
    %>
      <div class="request-card">
        <div class="request-card__main">
          <div class="request-card__name">
            <strong><%= req.medicineName %></strong>
            <span class="request-card__shape"><%= req.shapeAndDose %></span>
          </div>
          <div class="request-card__company">
            <i class="ph ph-building"></i> <%= req.companyName %>
          </div>
        </div>
        <div class="request-card__meta">
          <div class="request-card__qty" title="<%= t.userMyRequests.thQty %>">
            <i class="ph ph-cube"></i> <%= req.quantity %>
          </div>
          <div class="request-card__date" title="<%= t.userMyRequests.thDate %>">
            <i class="ph ph-calendar"></i> <%= date %>
          </div>
          <span class="badge <%= badgeClass %>"><%= req.status %></span>
        </div>
      </div>
    <% }) %>
  <% } else { %>
    <!-- Empty State -->
    <div class="empty-state">
      <i class="ph ph-notebook empty-state__icon"></i>
      <p class="empty-state__text"><%= t.userMyRequests.noRequestsIcon %></p>
    </div>
  <% } %>
</div>

<%- include('../partials/mobile-nav', { page: 'my-requests' }) %>

<script>
  // Highlight active mobile nav link
  const currentPath = window.location.pathname;
  document.querySelectorAll('.mobile-bottom-nav a').forEach(link => {
    if (link.getAttribute('href') === currentPath) {
      link.classList.add('active');
    }
  });
</script>

<%- include('../partials/footer') %>