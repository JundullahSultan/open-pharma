<%- include('../partials/user-header', { title: t.userDashboard.title, page: 'dashboard' }) %>

<style>
  /* ==============================
     MEDICINE LIST – COMPACT & POLISHED
     ============================== */

  .medicine-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 1.25rem;
    padding: 0 0.25rem;
  }
  
  @media (min-width: 600px) {
    .medicine-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 960px) {
    .medicine-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .product-card {
    background: var(--surface-dark);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    overflow: hidden;
    transition: box-shadow var(--transition-fast), border-color var(--transition-fast), transform 0.1s ease;
  }

  .product-card:hover {
    border-color: var(--primary);
    box-shadow: var(--shadow-md);
  }

  .product-compact {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
    cursor: pointer;
    user-select: none;
    transition: background var(--transition-fast);
  }

  .product-compact:hover {
    background: var(--surface-light);
  }

  .product-img-small {
    width: 65px;
    height: 65px;
    border-radius: 10px;
    background: var(--surface-light);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid var(--glass-border);
  }

  .product-img-small img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-img-small .img-fallback {
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--text-muted);
  }

  .product-summary {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .product-summary h4 {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-main);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .company {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .product-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.9rem;
    margin-top: 0.25rem;
  }

  .price {
    font-weight: 700;
    color: var(--primary);
  }

  .stock {
    color: var(--text-main);
    background: var(--surface-light);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .stock.out {
    color: var(--danger);
    background: rgba(239, 68, 68, 0.12);
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  .toggle-details {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 1.25rem;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .toggle-details:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--text-main);
  }

  .toggle-details.open {
    color: var(--primary);
    background: rgba(59, 130, 246, 0.1);
  }

  .toggle-details.open i {
    transform: rotate(180deg);
  }

  .product-details {
    max-height: 0;
    overflow: hidden;
    background: var(--bg-dark);
    transition: max-height 0.3s ease-out;
  }

  .product-details.show {
    max-height: 400px;
    border-top: 1px solid var(--glass-border);
  }

  .details-inner {
    padding: 1.25rem;
  }

  .details-description {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    line-height: 1.6;
  }

  /* Order Form */
  .order-form {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    background: var(--surface-dark);
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid var(--glass-border);
  }

  .qty-control {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .qty-control label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-muted);
  }

  .qty-control input[type="number"] {
    width: 80px;
    padding: 0.6rem;
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 600;
    background: var(--bg-dark);
    color: var(--text-main);
    outline: none;
    text-align: center;
  }

  .qty-control input[type="number"]:focus {
    border-color: var(--primary);
  }

  .order-form .order-btn {
    flex: 1;
    min-width: 150px;
  }

  @media (max-width: 480px) {
    .order-form {
      flex-direction: column;
      align-items: stretch;
    }
    .qty-control {
      justify-content: space-between;
    }
    .qty-control input[type="number"] {
      width: 100px;
    }
  }
</style>

<div class="medicine-grid">
  <% medicines.forEach(med => { %>
    <div class="product-card">
      
      <div class="product-compact" role="button" tabindex="0" onclick="toggleDetails(this)">
        <div class="product-img-small">
          <% if (med.imageURL) { %>
            <img src="<%= med.imageURL %>" alt="<%= med.name %>" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
            <span class="img-fallback" style="display:none;"><%= med.name.charAt(0).toUpperCase() %></span>
          <% } else { %>
            <span class="img-fallback"><%= med.name.charAt(0).toUpperCase() %></span>
          <% } %>
        </div>
        
        <div class="product-summary">
          <h4><%= med.name %></h4>
          <p class="company"><%= med.companyName %></p>
          <div class="product-meta">
            <span class="price">؋ <%= med.price.toLocaleString() %></span>
            <span class="stock <%= med.stock == 0 ? 'out' : '' %>">
              <%= med.stock > 0 ? med.stock + ' ' + t.adminMedicines.inStock : t.userDashboard.outOfStock %>
            </span>
          </div>
        </div>
        
        <button class="toggle-details" aria-label="Show details">
          <i class="ph ph-caret-down"></i>
        </button>
      </div>

      <div class="product-details">
        <div class="details-inner">
          <div class="details-description">
            <%= med.description || t.userDashboard.noDescription %>
          </div>
          
          <form class="order-form">
            <input type="hidden" name="medicineId" value="<%= med._id %>">
            <input type="hidden" name="price" value="<%= med.price %>"> 
            
            <div class="qty-control">
              <label><%= t.userDashboard.quantityLabel %></label>
              <input type="number" name="quantity" min="1" max="<%= med.stock %>" value="1" required <%= med.stock == 0 ? 'disabled' : '' %>>
            </div>
            
            <button type="submit" class="order-btn" <%= med.stock == 0 ? 'disabled' : '' %>>
              <i class="ph ph-shopping-cart"></i> 
              <%= med.stock == 0 ? t.userDashboard.outOfStockBtn : t.userDashboard.placeOrder %>
            </button>
          </form>

        </div>
      </div>
    </div>
  <% }) %>
</div>

<div class="mobile-spacer" style="height: 100px"></div>

<%- include('../partials/mobile-nav', { page: 'dashboard' }) %>

<script>
  // Active mobile nav
  const currentPath = window.location.pathname;
  document.querySelectorAll('.mobile-bottom-nav a').forEach(link => {
    if (link.getAttribute('href') === currentPath) link.classList.add('active');
  });

  // Toggle details dropdown
  function toggleDetails(row) {
    const card = row.closest('.product-card');
    const details = card.querySelector('.product-details');
    const button = card.querySelector('.toggle-details');
    const isOpen = details.classList.contains('show');

    if (isOpen) {
      details.classList.remove('show');
      button.classList.remove('open');
    } else {
      // Close all others first
      document.querySelectorAll('.product-details.show').forEach(d => {
        if (d !== details) {
          d.classList.remove('show');
          d.closest('.product-card').querySelector('.toggle-details').classList.remove('open');
        }
      });
      // Open clicked one
      details.classList.add('show');
      button.classList.add('open');
    }
  }
</script>

<script src="/js/user-medicine.js"></script>

<%- include('../partials/footer') %>