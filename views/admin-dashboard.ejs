<%- include('partials/admin-header', { title: t.adminDashboard.title, page: 'dashboard' }) %>

<style>
    /* ===== GLOBAL ANIMATIONS ===== */
    @keyframes slideUpFade {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ===== COMPACT STATS ===== */
    .compact-stats {
        display: flex;
        flex-wrap: wrap; 
        gap: 12px;
        margin-bottom: 20px;
    }
    .stat-card-mini {
        flex: 1 1 130px;
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background: var(--surface-dark);
        border-radius: 12px;
        border: 1px solid var(--glass-border);
        border-top: 3px solid transparent;
        box-shadow: var(--shadow-sm);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .stat-card-mini:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }
    .stat-card-mini.pending  { border-top-color: var(--warning); }
    .stat-card-mini.approved { border-top-color: var(--success); }
    .stat-card-mini.cancelled { border-top-color: var(--danger); }

    .stat-card-mini .stat-icon {
        font-size: 1.35rem;
        width: 36px;
        height: 36px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .stat-card-mini.pending .stat-icon  { color: var(--warning); background: rgba(245,158,11,0.12); }
    .stat-card-mini.approved .stat-icon { color: var(--success); background: rgba(16,185,129,0.12); }
    .stat-card-mini.cancelled .stat-icon { color: var(--danger); background: rgba(239,68,68,0.12); }

    .stat-card-mini h3 { margin: 0; font-size: 1.25rem; font-weight: 700; color: var(--text-main); line-height: 1; }
    .stat-card-mini p  { margin: 4px 0 0 0; font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;}

    /* ===== DASHBOARD LAYOUT ===== */
    .dashboard-layout {
        display: grid;
        grid-template-columns: 2.5fr 1fr; 
        gap: 16px;
        align-items: start;
    }
    @media (max-width: 992px) {
        .dashboard-layout { grid-template-columns: 1fr; }
    }

    /* ===== DENSE ORDERS GRID ===== */
    .orders-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); 
        gap: 12px;
    }

    .order-card {
        background: linear-gradient(145deg, var(--surface-dark) 0%, rgba(255,255,255,0.01) 100%);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 12px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        box-shadow: var(--shadow-sm);
        transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        position: relative;
        overflow: hidden;
    }
    .order-card:hover {
        border-color: var(--primary);
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        transform: translateY(-3px);
    }

    .order-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 8px;
    }
    .order-card-medicine {
        font-weight: 600;
        font-size: 0.95rem;
        color: var(--text-main);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .order-card-total {
        font-weight: 800;
        font-size: 0.9rem;
        color: var(--primary);
        white-space: nowrap;
        background: rgba(59, 130, 246, 0.1);
        padding: 2px 6px;
        border-radius: 6px;
    }

    .order-card-middle {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.75rem;
    }
    .order-card-pharmacy {
        display: flex;
        align-items: center;
        gap: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 100px;
        color: var(--text-muted);
        background: var(--bg-dark);
        padding: 2px 6px;
        border-radius: 12px;
        border: 1px solid var(--glass-border);
    }

    /* Pill Badges */
    .order-card .badge {
        padding: 2px 8px;
        font-size: 0.65rem;
        border-radius: 20px;
        font-weight: 700;
        text-transform: capitalize;
        letter-spacing: 0.3px;
    }
    .badge.pending { background: rgba(245,158,11,0.15); color: #fbbf24; border: 1px solid rgba(245,158,11,0.2); }
    .badge.approved { background: rgba(16,185,129,0.15); color: #34d399; border: 1px solid rgba(16,185,129,0.2); }
    .badge.cancelled { background: rgba(239,68,68,0.15); color: #f87171; border: 1px solid rgba(239,68,68,0.2); }

    .order-card-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 4px;
        padding-top: 10px;
        border-top: 1px dashed var(--glass-border);
    }

    /* Miniature Buttons */
    .order-eye-btn, .order-action-btn {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: 1px solid var(--glass-border);
        background: var(--surface-light);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        font-size: 1rem;
    }
    .order-eye-btn { color: var(--text-muted); }
    .order-eye-btn:hover { color: var(--primary); background: rgba(59,130,246,0.15); border-color: var(--primary); }
    
    .order-action-btn.approve { color: var(--success); }
    .order-action-btn.approve:hover { background: var(--success); color: white; border-color: var(--success); }
    
    .order-action-btn.cancel { color: var(--danger); }
    .order-action-btn.cancel:hover { background: var(--danger); color: white; border-color: var(--danger); }

    /* Premium Section Styling */
    .premium-card {
        margin: 0; 
        padding: 16px; 
        background: linear-gradient(135deg, var(--surface-dark) 0%, rgba(59, 130, 246, 0.05) 100%);
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 12px;
        box-shadow: var(--shadow-sm);
    }
    .premium-card ul li {
        padding: 8px 10px;
        background: rgba(0,0,0,0.15);
        border-radius: 8px;
        border: 1px solid var(--glass-border);
        transition: transform 0.2s;
    }
    .premium-card ul li:hover {
        transform: translateX(4px);
        border-color: rgba(59,130,246,0.3);
    }
    .premium-icon-box {
        background: var(--surface-light);
        padding: 6px;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Modal Styling */
    .custom-backdrop {
        display: none; 
        position: fixed; 
        top: 0; left: 0; 
        width: 100vw; height: 100vh; 
        background: rgba(0,0,0,0.6); 
        backdrop-filter: blur(6px);
        z-index: 9999; 
        align-items: center; 
        justify-content: center;
    }
    .modal-content-animated {
        max-width: 500px; /* Wider for the beautiful grid */
        width: 95%; 
        padding: 24px; 
        background: var(--surface-dark); 
        border: 1px solid var(--glass-border); 
        border-radius: 20px; 
        box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
        animation: slideUpFade 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }
    
    .modal-info-group {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
        margin-bottom: 20px;
    }
    @media (max-width: 480px) {
        .modal-info-group { grid-template-columns: 1fr; }
    }
    .info-item {
        display: flex;
        align-items: center;
        gap: 12px;
        background: var(--bg-dark);
        padding: 12px 16px;
        border-radius: 12px;
        border: 1px solid var(--glass-border);
        transition: transform 0.2s, border-color 0.2s;
    }
    .info-item:hover { transform: translateY(-2px); border-color: rgba(255,255,255,0.1); }
    .info-icon {
        width: 38px; height: 38px;
        border-radius: 10px;
        background: rgba(59, 130, 246, 0.1);
        color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.3rem;
        flex-shrink: 0;
    }
    .info-text { display: flex; flex-direction: column; gap: 2px; overflow: hidden; }
    .info-label { font-size: 0.7rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; }
    .info-value { font-size: 0.95rem; color: var(--text-main); font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    
    .modal-total-row {
        display: flex; justify-content: space-between; align-items: center;
        background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(59, 130, 246, 0.02));
        border: 1px solid rgba(59, 130, 246, 0.2);
        padding: 20px; 
        border-radius: 14px; 
        margin-bottom: 16px;
    }
    .total-amount { font-size: 1.8rem; font-weight: 800; color: var(--primary); line-height: 1; margin-top: 4px; display: block;}
    
    .modal-notes {
        background: rgba(245, 158, 11, 0.05);
        border: 1px dashed rgba(245, 158, 11, 0.3);
        padding: 16px;
        border-radius: 12px;
    }
    .notes-header { display: flex; align-items: center; gap: 8px; color: var(--warning); font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
    .modal-notes p { margin: 0; color: var(--text-main); font-size: 0.9rem; line-height: 1.5; }

    /* Section Headers */
    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }
    .section-header h2 { font-size: 1.15rem; margin: 0; font-weight: 700; }
    .section-header .btn-text { font-size: 0.8rem; padding: 4px 8px; font-weight: 600; }
</style>

<div id="toast-container"></div>

<section class="compact-stats">
    <div class="stat-card-mini pending">
        <div class="stat-icon"><i class="ph ph-clock"></i></div>
        <div>
            <h3><%= pendingOrders %></h3>
            <p><%- t.adminDashboard.pending %></p>
        </div>
    </div>
    <div class="stat-card-mini approved">
        <div class="stat-icon"><i class="ph ph-check-circle"></i></div>
        <div>
            <h3><%= approvedOrders %></h3>
            <p><%- t.adminDashboard.approved %></p>
        </div>
    </div>
    <div class="stat-card-mini cancelled">
        <div class="stat-icon"><i class="ph ph-x-circle"></i></div>
        <div>
            <h3><%= cancelledOrders %></h3>
            <p><%- t.adminDashboard.cancelled %></p>
        </div>
    </div>
</section>

<div class="dashboard-layout">
    
    <section class="card" style="margin: 0; padding: 16px; border-radius: 12px;">
        <div class="section-header">
            <h2><%- t.adminDashboard.recentOrders %></h2>
            <a href="/admin/orders" class="btn-text" style="text-decoration:none;"><%- t.common.viewAll %> <i class="ph ph-arrow-right"></i></a>
        </div>

        <div class="orders-grid" id="orders-grid">
            <% orders.forEach((order) => { %>
            <div class="order-card" id="order-card-<%= order._id %>" data-status="<%= order.status.toLowerCase() %>">
                
                <div class="order-card-top">
                    <span class="order-card-medicine" title="<%= order.medicineId ? order.medicineId.name : '' %>">
                        <%= order.medicineId ? order.medicineId.name : t.adminOrders.deletedMedicine %>
                    </span>
                    <span class="order-card-total">؋<%= order.totalPrice.toLocaleString() %></span>
                </div>
                
                <div class="order-card-middle">
                    <div class="order-card-pharmacy" title="<%= order.user ? (order.user.pharmacy || order.user.name) : t.adminOrders.unknownUser %>">
                        <i class="ph ph-storefront"></i>
                        <span><%= order.user ? (order.user.pharmacy || order.user.name) : t.adminOrders.unknownUser %></span>
                    </div>
                    <span class="badge <%= order.status.toLowerCase() %>" id="badge-<%= order._id %>"><%= order.status %></span>
                </div>
                
                <div class="order-card-actions">
                    <button class="order-eye-btn" 
                            data-order="<%= encodeURIComponent(JSON.stringify(order)) %>"
                            onclick="openOrderDetail(this)" 
                            title="View details">
                        <i class="ph ph-eye"></i>
                    </button>
                    
                    <% if(order.status.toLowerCase() === 'pending') { %>
                        <div class="actions" id="actions-<%= order._id %>" style="display:flex; gap:8px;">
                            <button class="order-action-btn approve action-btn" data-id="<%= order._id %>" data-status="approved" title="Approve">
    <i class="ph ph-check" style="stroke-width: 30px;"></i>
</button>
<button class="order-action-btn cancel action-btn" data-id="<%= order._id %>" data-status="cancelled" title="Cancel">
    <i class="ph ph-x" style="stroke-width: 30px;"></i>
</button>
                        </div>
                    <% } else { %>
                        <span class="text-muted" style="font-size:0.8rem; font-weight:600;">-</span>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>
    </section>

    <section class="premium-card">
        <div class="section-header">
            <h2 style="font-size: 1.05rem;"><i class="ph ph-sparkle" style="color:var(--primary);"></i> <%= t.futureEnhancements ? t.futureEnhancements.title : 'Coming Soon' %></h2>
        </div>
        <div style="color: var(--text-muted); font-size: 0.85rem; line-height: 1.5;">
            <p style="margin-top: 0; margin-bottom: 12px;"><%= t.futureEnhancements ? t.futureEnhancements.description : 'Reserved space for upcoming features:' %></p>
            
            <ul style="padding-left: 0; list-style: none; display: flex; flex-direction: column; gap: 8px; margin: 0;">
                <li style="display:flex; gap:10px; align-items:center;">
                    <div class="premium-icon-box"><i class="ph ph-chart-line-up" style="color:var(--primary); font-size: 1.1rem;"></i></div>
                    <div>
                        <strong style="color:var(--text-main); display:block; font-size: 0.9rem;"><%= t.futureEnhancements ? t.futureEnhancements.revenue : 'Revenue Analytics' %></strong> 
                    </div>
                </li>
                <li style="display:flex; gap:10px; align-items:center;">
                    <div class="premium-icon-box"><i class="ph ph-warning" style="color:var(--warning); font-size: 1.1rem;"></i></div>
                    <div>
                        <strong style="color:var(--text-main); display:block; font-size: 0.9rem;"><%= t.futureEnhancements ? t.futureEnhancements.lowStock : 'Low Stock Alerts' %></strong> 
                    </div>
                </li>
                <li style="display:flex; gap:10px; align-items:center;">
                    <div class="premium-icon-box"><i class="ph ph-clock-counter-clockwise" style="color:var(--success); font-size: 1.1rem;"></i></div>
                    <div>
                        <strong style="color:var(--text-main); display:block; font-size: 0.9rem;"><%= t.futureEnhancements ? t.futureEnhancements.activityFeed : 'Activity Feed' %></strong> 
                    </div>
                </li>
            </ul>
        </div>
    </section>
</div>

<div class="custom-backdrop" id="orderDetailModal">
    <div class="modal-content-animated">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.25rem;">
            <h3 style="margin:0; font-size:1.2rem; display: flex; align-items: center; gap: 8px;">
                <i class="ph ph-receipt" style="color:var(--primary);"></i> Order Details
            </h3>
            <button type="button" onclick="closeOrderDetail()" style="background: var(--surface-light); border: 1px solid var(--glass-border); border-radius: 50%; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; color: var(--text-main); cursor: pointer; transition: background 0.2s;">
                <i class="ph ph-x"></i>
            </button>
        </div>
        <div id="orderDetailContent"></div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const orderDetailModal = document.getElementById('orderDetailModal');
        const toastContainer = document.getElementById('toast-container');
        
        if(orderDetailModal) document.body.appendChild(orderDetailModal);
        if(toastContainer) document.body.appendChild(toastContainer);
    });

    // --- SAFE MODAL DATA PARSING & BEAUTIFUL UI ---
    window.openOrderDetail = function(btn) {
        try {
            const encodedData = btn.getAttribute('data-order');
            const order = JSON.parse(decodeURIComponent(encodedData));
            
            // Translations and formatting
            const medicineName = order.medicineId ? order.medicineId.name : '<%= t.adminOrders ? t.adminOrders.deletedMedicine : "Deleted Medicine" %>';
            const pharmacyName = order.user ? (order.user.pharmacy || order.user.name) : '<%= t.adminOrders ? t.adminOrders.unknownUser : "Unknown User" %>';
            const orderDate = order.createdAt ? new Date(order.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : 'N/A';
            const quantity = order.quantity || 'N/A';

            // Dynamic Status colors
            const statusColors = {
                'pending': { bg: 'rgba(245,158,11,0.1)', color: 'var(--warning)', icon: 'ph-clock' },
                'approved': { bg: 'rgba(16,185,129,0.1)', color: 'var(--success)', icon: 'ph-check-circle' },
                'cancelled': { bg: 'rgba(239,68,68,0.1)', color: 'var(--danger)', icon: 'ph-x-circle' }
            };
            const sType = order.status.toLowerCase();
            const sStyle = statusColors[sType] || statusColors['pending'];

            const content = document.getElementById('orderDetailContent');
            content.innerHTML = `
                <div class="modal-info-group">
                    <div class="info-item">
                        <div class="info-icon"><i class="ph ph-pill"></i></div>
                        <div class="info-text">
                            <span class="info-label">Medicine</span>
                            <span class="info-value" title="${medicineName}">${medicineName}</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-icon" style="color: #f59e0b; background: rgba(245,158,11,0.1);"><i class="ph ph-cube"></i></div>
                        <div class="info-text">
                            <span class="info-label">Quantity</span>
                            <span class="info-value">${quantity}</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-icon" style="color: #10b981; background: rgba(16,185,129,0.1);"><i class="ph ph-storefront"></i></div>
                        <div class="info-text">
                            <span class="info-label">Pharmacy</span>
                            <span class="info-value" title="${pharmacyName}">${pharmacyName}</span>
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-icon" style="color: #a855f7; background: rgba(168,85,247,0.1);"><i class="ph ph-calendar-blank"></i></div>
                        <div class="info-text">
                            <span class="info-label">Date & Time</span>
                            <span class="info-value" style="font-size: 0.85rem;">${orderDate}</span>
                        </div>
                    </div>
                    <div class="info-item" style="grid-column: 1 / -1;">
                        <div class="info-icon" style="color: var(--text-muted); background: var(--surface-light);"><i class="ph ph-hash"></i></div>
                        <div class="info-text">
                            <span class="info-label">Reference ID</span>
                            <span class="info-value" style="font-family: monospace; font-size: 0.9rem; letter-spacing: 1px;">#${order._id.slice(-6).toUpperCase()}</span>
                        </div>
                    </div>
                </div>

                <div class="modal-total-row">
                    <div style="display:flex; flex-direction:column; gap:4px;">
                        <span class="info-label" style="color: var(--text-muted);">Current Status</span>
                        <div style="display:flex; align-items:center; gap:6px; color: ${sStyle.color}; font-weight:800; font-size:1.2rem;">
                            <i class="ph ${sStyle.icon}"></i> <span style="text-transform: capitalize;">${order.status}</span>
                        </div>
                    </div>
                    <div style="text-align:right;">
                        <span class="info-label" style="display:block; color: var(--primary);">Total Price</span>
                        <span class="total-amount">؋${order.totalPrice.toLocaleString()}</span>
                    </div>
                </div>

                ${order.notes ? `
                <div class="modal-notes">
                    <div class="notes-header"><i class="ph ph-chat-text"></i> Customer Notes</div>
                    <p>${order.notes}</p>
                </div>` : ''}
            `;
            document.getElementById('orderDetailModal').style.display = 'flex';
        } catch (err) {
            console.error("Error reading order data", err);
        }
    }

    window.closeOrderDetail = function() {
        document.getElementById('orderDetailModal').style.display = 'none';
    }

    document.getElementById('orderDetailModal').addEventListener('click', function(e) {
        if (e.target === this) closeOrderDetail();
    });

    // --- Toast Helper ---
    function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        if (!container) return alert(message);
        
        const toast = document.createElement('div');
        const icon = type === 'success' ? '<i class="ph ph-check-circle"></i>' : '<i class="ph ph-warning-circle"></i>';
        toast.className = `toast ${type}`; 
        toast.innerHTML = `${icon} <span>${message}</span>`;
        container.appendChild(toast);
        
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-20px)';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    // --- Order Actions (Approve/Cancel) ---
    document.querySelectorAll('.action-btn').forEach(btn => {
        btn.addEventListener('click', async function() {
            const id = this.dataset.id;
            const newStatus = this.dataset.status;
            const originalHTML = this.innerHTML;
            this.innerHTML = '<i class="ph ph-spinner ph-spin"></i>';
            this.disabled = true;

            try {
                const res = await fetch(`/admin/orders/${id}/status`, { 
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: newStatus })
                });
                const result = await res.json();
                
                if (res.ok) {
                    showToast(`Order ${newStatus} successfully!`, 'success');
                    
                    const card = document.getElementById(`order-card-${id}`);
                    const badge = card.querySelector('.badge');
                    const actionsDiv = card.querySelector('.actions');
                    
                    if (badge) {
                        badge.className = `badge ${newStatus}`;
                        badge.innerText = newStatus;
                    }
                    if (actionsDiv) {
                        actionsDiv.innerHTML = '<span class="text-muted" style="font-size:0.8rem; font-weight:600;">-</span>';
                    }
                    
                    card.dataset.status = newStatus;
                    
                    const eyeBtn = card.querySelector('.order-eye-btn');
                    if (eyeBtn) {
                        const orderData = JSON.parse(decodeURIComponent(eyeBtn.getAttribute('data-order')));
                        orderData.status = newStatus;
                        eyeBtn.setAttribute('data-order', encodeURIComponent(JSON.stringify(orderData)));
                    }
                } else {
                    showToast(result.message || 'Update failed', 'error');
                    this.innerHTML = originalHTML;
                    this.disabled = false;
                }
            } catch (err) {
                showToast('Network error', 'error');
                this.innerHTML = originalHTML;
                this.disabled = false;
            }
        });
    });
</script>

