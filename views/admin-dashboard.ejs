<%- include('partials/admin-header', { title: t.adminDashboard.title, page: 'dashboard' }) %>

<style>
    /* ===== Compact stats – Fully Responsive ===== */
    .compact-stats {
        display: flex;
        flex-wrap: wrap; /* Allows cards to wrap to the next line on small screens */
        gap: 12px;
        margin-bottom: 20px;
    }
    .stat-card-mini {
        flex: 1 1 140px; /* Grow and shrink, wrapping when smaller than 140px */
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 14px;
        background: var(--surface-dark);
        border-radius: 10px;
        border: 1px solid var(--glass-border);
        box-shadow: var(--shadow-sm);
    }
    /* Coloured left accent */
    .stat-card-mini.pending  { border-left: 3px solid var(--warning); }
    .stat-card-mini.approved { border-left: 3px solid var(--success); }
    .stat-card-mini.cancelled { border-left: 3px solid var(--danger); }

    .stat-card-mini .stat-icon {
        font-size: 1.5rem;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 6px;
        flex-shrink: 0;
    }
    .stat-card-mini.pending .stat-icon  { color: var(--warning); background: rgba(245,158,11,0.1); }
    .stat-card-mini.approved .stat-icon { color: var(--success); background: rgba(16,185,129,0.1); }
    .stat-card-mini.cancelled .stat-icon { color: var(--danger); background: rgba(239,68,68,0.1); }

    .stat-card-mini h3 { margin: 0; font-size: 1.25rem; color: var(--text-main); }
    .stat-card-mini p  { margin: 0; font-size: 0.75rem; color: var(--text-muted); }

    /* ===== Dashboard layout ===== */
    .dashboard-layout {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
        align-items: start;
    }
    @media (max-width: 992px) {
        .dashboard-layout { grid-template-columns: 1fr; }
    }

    /* ===== Orders grid (exactly like the Orders page) ===== */
    .orders-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        gap: 12px;
    }

    .order-card {
        background: var(--surface-dark);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        padding: 14px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        box-shadow: var(--shadow-sm);
        transition: box-shadow var(--transition-fast), transform var(--transition-fast);
    }
    .order-card:hover {
        box-shadow: var(--shadow-md);
        transform: translateY(-1px);
    }

    .order-card-top {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }
    .order-card-medicine {
        font-weight: 600;
        color: var(--text-main);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 65%;
    }
    .order-card-total {
        font-weight: 700;
        color: var(--text-main);
        white-space: nowrap;
    }

    .order-card-middle {
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: var(--text-muted);
        font-size: 0.85rem;
    }
    .order-card-pharmacy {
        display: flex;
        align-items: center;
        gap: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        max-width: 140px;
    }

    .order-card-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 8px;
    }

    .order-eye-btn {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid var(--glass-border);
        background: transparent;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all var(--transition-fast);
    }
    .order-eye-btn:hover {
        color: var(--primary);
        background: rgba(59,130,246,0.1);
        border-color: var(--primary);
    }

    .order-action-btn {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        border: 1px solid var(--glass-border);
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all var(--transition-fast);
    }
    .order-action-btn.approve {
        color: var(--success);
        border-color: var(--success);
    }
    .order-action-btn.approve:hover {
        background: var(--success);
        color: white;
    }
    .order-action-btn.cancel {
        color: var(--danger);
        border-color: var(--danger);
    }
    .order-action-btn.cancel:hover {
        background: var(--danger);
        color: white;
    }

    /* Modal detail grid */
    #orderDetailModal .detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        font-size: 0.95rem;
        margin-bottom: 1rem;
        background: var(--surface-light);
        padding: 1.5rem;
        border-radius: 12px;
        border: 1px solid var(--glass-border);
    }
    @media (max-width: 480px) {
        #orderDetailModal .detail-grid {
            grid-template-columns: 1fr;
        }
    }
    #orderDetailModal .detail-grid p { margin: 0; color: var(--text-main); }
    #orderDetailModal .detail-grid strong {
        display: block;
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>

<div id="toast-container"></div>

<section class="compact-stats">
    <div class="stat-card-mini pending">
        <div class="stat-icon"><i class="ph ph-clock"></i></div>
        <div>
            <h3><%= pendingOrders %></h3>
            <p><%- t.adminDashboard.pending %></p>
        </div>
    </div>
    <div class="stat-card-mini approved">
        <div class="stat-icon"><i class="ph ph-check-circle"></i></div>
        <div>
            <h3><%= approvedOrders %></h3>
            <p><%- t.adminDashboard.approved %></p>
        </div>
    </div>
    <div class="stat-card-mini cancelled">
        <div class="stat-icon"><i class="ph ph-x-circle"></i></div>
        <div>
            <h3><%= cancelledOrders %></h3>
            <p><%- t.adminDashboard.cancelled %></p>
        </div>
    </div>
</section>

<div class="dashboard-layout">
    
    <section class="card" style="margin: 0;">
        <div class="card-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
            <h2><%- t.adminDashboard.recentOrders %></h2>
            <button class="btn-text"><a href="/admin/orders"><%- t.common.viewAll %></a></button>
        </div>

        <div class="orders-grid" id="orders-grid">
            <% orders.forEach((order) => { %>
            <div class="order-card" id="order-card-<%= order._id %>" data-status="<%= order.status.toLowerCase() %>">
                <div class="order-card-top">
                    <span class="order-card-medicine" title="<%= order.medicineId ? order.medicineId.name : '' %>">
                        <%= order.medicineId ? order.medicineId.name : t.adminOrders.deletedMedicine %>
                    </span>
                    <span class="order-card-total">$<%= order.totalPrice %></span>
                </div>
                <div class="order-card-middle">
                    <div class="order-card-pharmacy">
                        <i class="ph ph-storefront"></i>
                        <span><%= order.user ? (order.user.pharmacy || order.user.name) : t.adminOrders.unknownUser %></span>
                    </div>
                    <span class="badge <%= order.status.toLowerCase() %>" id="badge-<%= order._id %>"><%= order.status %></span>
                </div>
                <div class="order-card-actions">
                    <button class="order-eye-btn" 
                            data-order="<%= encodeURIComponent(JSON.stringify(order)) %>"
                            onclick="openOrderDetail(this)" 
                            title="View details">
                        <i class="ph ph-eye"></i>
                    </button>
                    
                    <% if(order.status.toLowerCase() === 'pending') { %>
                        <div class="actions" id="actions-<%= order._id %>" style="display:flex; gap:8px;">
                            <button class="order-action-btn approve action-btn" data-id="<%= order._id %>" data-status="approved" title="Approve">
                                <i class="ph ph-check"></i>
                            </button>
                            <button class="order-action-btn cancel action-btn" data-id="<%= order._id %>" data-status="cancelled" title="Cancel">
                                <i class="ph ph-x"></i>
                            </button>
                        </div>
                    <% } else { %>
                        <span class="text-muted">-</span>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>
    </section>

    <section class="card" style="margin: 0; background: var(--surface-dark); border: 1px dashed var(--glass-border);">
        <div class="card-header">
            <h2><i class="ph ph-lightbulb"></i> <%= t.futureEnhancements ? t.futureEnhancements.title : 'Future Enhancements' %></h2>
        </div>
        <div style="padding: 15px; color: var(--text-muted); font-size: 0.95rem; line-height: 1.6;">
            <p style="margin-top: 0;"><%= t.futureEnhancements ? t.futureEnhancements.description : 'This dedicated space is reserved for features you plan to add later. Suggestions for this area:' %></p>
            
            <ul style="margin-top: 15px; padding-left: 20px; display: flex; flex-direction: column; gap: 12px;">
                <li>
                    <strong><i class="ph ph-chart-line-up"></i> <%= t.futureEnhancements ? t.futureEnhancements.revenue : 'Revenue Analytics:' %></strong> 
                    <%= t.futureEnhancements ? t.futureEnhancements.revenueDesc : 'Integrate Chart.js to visualize weekly or monthly sales growth.' %>
                </li>
                <li>
                    <strong><i class="ph ph-warning"></i> <%= t.futureEnhancements ? t.futureEnhancements.lowStock : 'Low Stock Alerts:' %></strong> 
                    <%= t.futureEnhancements ? t.futureEnhancements.lowStockDesc : 'Query the database for stockQuantity < 10 and list medicines requiring immediate restock.' %>
                </li>
                <li>
                    <strong><i class="ph ph-clock-counter-clockwise"></i> <%= t.futureEnhancements ? t.futureEnhancements.activityFeed : 'Activity Feed:' %></strong> 
                    <%= t.futureEnhancements ? t.futureEnhancements.activityFeedDesc : 'A log showing recent administrative actions (e.g., "Medicine X updated", "User Y deleted").' %>
                </li>
            </ul>
        </div>
    </section>
</div>

<div class="custom-backdrop" id="orderDetailModal" style="display:none;">
    <div class="modal-content" style="max-width: 480px; width: 95%; padding: 2rem; display: block; opacity: 1;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h3 style="margin:0;">Order Details</h3>
            <button type="button" onclick="closeOrderDetail()" style="background: transparent; border: none; color: var(--text-muted); font-size: 1.5rem; cursor: pointer; line-height: 1;">&times;</button>
        </div>
        <div id="orderDetailContent"></div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const orderDetailModal = document.getElementById('orderDetailModal');
        const toastContainer = document.getElementById('toast-container');
        
        if(orderDetailModal) document.body.appendChild(orderDetailModal);
        if(toastContainer) document.body.appendChild(toastContainer);
    });

    // --- SAFE MODAL DATA PARSING ---
    window.openOrderDetail = function(btn) {
        try {
            const encodedData = btn.getAttribute('data-order');
            const order = JSON.parse(decodeURIComponent(encodedData));
            const medicineName = order.medicineId ? order.medicineId.name : '<%= t.adminOrders.deletedMedicine %>';
            const pharmacyName = order.user ? (order.user.pharmacy || order.user.name) : '<%= t.adminOrders.unknownUser %>';
            const orderDate = order.createdAt ? new Date(order.createdAt).toLocaleDateString('en-US') : 'N/A';

            const content = document.getElementById('orderDetailContent');
            content.innerHTML = `
                <div class="detail-grid">
                    <p><strong>Medicine</strong> ${medicineName}</p>
                    <p><strong>Pharmacy</strong> ${pharmacyName}</p>
                    <p><strong>Date</strong> ${orderDate}</p>
                    <p><strong>Total</strong> $${order.totalPrice}</p>
                    <p><strong>Status</strong> <span class="badge ${order.status.toLowerCase()}">${order.status}</span></p>
                    <p><strong>ID</strong> <code style="font-size:0.75rem; color: var(--text-muted);">${order._id}</code></p>
                </div>
                ${order.notes ? `<div style="background: var(--surface-light); padding: 1rem; border-radius: 8px; border: 1px solid var(--glass-border);"><strong>Notes</strong><br/><p style="margin-top:5px; color: var(--text-main); font-size: 0.9rem;">${order.notes}</p></div>` : ''}
            `;
            
            document.getElementById('orderDetailModal').style.display = 'flex';
        } catch (err) {
            console.error("Error reading order data", err);
        }
    }

    window.closeOrderDetail = function() {
        document.getElementById('orderDetailModal').style.display = 'none';
    }

    document.getElementById('orderDetailModal').addEventListener('click', function(e) {
        if (e.target === this) closeOrderDetail();
    });

    // --- Toast Helper ---
    function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        if (!container) return alert(message);
        
        const toast = document.createElement('div');
        const icon = type === 'success' ? '<i class="ph ph-check-circle"></i>' : '<i class="ph ph-warning-circle"></i>';
        toast.className = `toast ${type}`; 
        toast.innerHTML = `${icon} <span>${message}</span>`;
        container.appendChild(toast);
        
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-20px)';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    // --- Order Actions (Approve/Cancel) ---
    document.querySelectorAll('.action-btn').forEach(btn => {
        btn.addEventListener('click', async function() {
            const id = this.dataset.id;
            const newStatus = this.dataset.status;
            const originalHTML = this.innerHTML;
            this.innerHTML = '<i class="ph ph-spinner ph-spin"></i>';
            this.disabled = true;

            try {
                const res = await fetch(`/admin/orders/${id}/status`, { 
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: newStatus })
                });
                const result = await res.json();
                
                if (res.ok) {
                    showToast(`Order ${newStatus} successfully!`, 'success');
                    
                    // Update badge in the same card
                    const card = document.getElementById(`order-card-${id}`);
                    const badge = card.querySelector('.badge');
                    const actionsDiv = card.querySelector('.actions');
                    
                    if (badge) {
                        badge.className = `badge ${newStatus}`;
                        badge.innerText = newStatus;
                    }
                    if (actionsDiv) {
                        actionsDiv.innerHTML = '<span class="text-muted">-</span>';
                    }
                    
                    // Update data-status for potential filtering later
                    card.dataset.status = newStatus;
                    
                    // Also update the hidden JSON object for the details modal
                    const eyeBtn = card.querySelector('.order-eye-btn');
                    if (eyeBtn) {
                        const orderData = JSON.parse(decodeURIComponent(eyeBtn.getAttribute('data-order')));
                        orderData.status = newStatus;
                        eyeBtn.setAttribute('data-order', encodeURIComponent(JSON.stringify(orderData)));
                    }
                } else {
                    showToast(result.message || 'Update failed', 'error');
                    this.innerHTML = originalHTML;
                    this.disabled = false;
                }
            } catch (err) {
                showToast('Network error', 'error');
                this.innerHTML = originalHTML;
                this.disabled = false;
            }
        });
    });
</script>

<%- include('partials/admin-footer', { page: 'dashboard' }) %>