<%- include('partials/admin-header', { title: t.adminMedicines.title, page: 'medicines' }) %>

<style>
    /* ===== COMPACT FORM GRID WITH FLOATING LABELS ===== */
    .create-medicine-card {
        background: linear-gradient(135deg, var(--surface-dark) 0%, rgba(59, 130, 246, 0.05) 100%);
        border: 1px solid rgba(59, 130, 246, 0.2);
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 20px;
        box-shadow: var(--shadow-sm);
    }
    .create-medicine-card h2 {
        margin-top: 0;
        margin-bottom: 16px;
        font-size: 1.15rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .create-medicine-card h2 i { color: var(--primary); }

    .grid-form-compact {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
    }
    @media (min-width: 600px) {
        .grid-form-compact { grid-template-columns: repeat(2, 1fr); }
    }
    @media (min-width: 992px) {
        .grid-form-compact { grid-template-columns: repeat(3, 1fr); }
        .field-full-width { grid-column: span 3; }
    }

    /* Floating Labels Styling */
    .floating-field {
        position: relative;
        display: flex;
        flex-direction: column;
    }
    .floating-field input, .floating-field textarea {
        width: 100%;
        padding: 18px 12px 6px 12px;
        background: var(--bg-dark);
        border: 1px solid var(--glass-border);
        border-radius: 8px;
        color: var(--text-main);
        font-size: 0.9rem;
        font-family: inherit;
        outline: none;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
        box-sizing: border-box;
    }
    .floating-field input:focus, .floating-field textarea:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
    }
    .floating-field label {
        position: absolute;
        top: 50%;
        left: 12px;
        transform: translateY(-50%);
        font-size: 0.85rem;
        color: var(--text-muted);
        pointer-events: none;
        transition: all 0.2s ease;
    }
    .floating-field textarea ~ label {
        top: 18px;
        transform: none;
    }
    /* Magic float triggers */
    .floating-field input:focus ~ label,
    .floating-field input:not(:placeholder-shown) ~ label,
    .floating-field textarea:focus ~ label,
    .floating-field textarea:not(:placeholder-shown) ~ label {
        top: 4px;
        transform: translateY(0);
        font-size: 0.65rem;
        font-weight: 700;
        color: var(--primary);
    }
    .floating-field input:not(:focus):not(:placeholder-shown) ~ label,
    .floating-field textarea:not(:focus):not(:placeholder-shown) ~ label {
        color: var(--text-muted);
    }

    /* Custom File Input Stylings */
    .file-upload-box {
        position: relative;
        display: flex;
        align-items: center;
        background: var(--bg-dark);
        border: 1px dashed var(--glass-border);
        border-radius: 8px;
        padding: 8px 12px;
        height: 44px;
        box-sizing: border-box;
        cursor: pointer;
    }
    .file-upload-box:hover { border-color: var(--primary); }
    .file-upload-box input[type="file"] {
        position: absolute; left: 0; top: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer;
    }
    .file-upload-box span { font-size: 0.8rem; color: var(--text-muted); display: flex; align-items: center; gap: 6px; }

    .btn-submit-med {
        grid-column: 1 / -1;
        background: var(--primary);
        color: white; border: none; padding: 10px; border-radius: 8px;
        font-weight: 600; font-size: 0.95rem; cursor: pointer;
        display: flex; align-items: center; justify-content: center; gap: 6px;
        transition: background 0.2s ease;
    }
    .btn-submit-med:hover { background: #2563eb; }

    /* Progress bar alignment */
    .progress-bar-wrapper {
        grid-column: 1 / -1;
        background: var(--bg-dark);
        border-radius: 4px;
        height: 6px;
        overflow: hidden;
        display: none;
        border: 1px solid var(--glass-border);
    }
    .progress-bar-fill { height: 100%; width: 0%; background: var(--primary); transition: width 0.1s ease; }

    /* ===== ULTRA DENSE MEDICINE GRID ===== */
    .medicine-dense-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
    }
    @media (min-width: 600px) { .medicine-dense-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (min-width: 900px) { .medicine-dense-grid { grid-template-columns: repeat(4, 1fr); } }
    @media (min-width: 1200px) { .medicine-dense-grid { grid-template-columns: repeat(6, 1fr); } }

    .med-card {
        background: linear-gradient(145deg, var(--surface-dark) 0%, rgba(255,255,255,0.01) 100%);
        border: 1px solid var(--glass-border);
        border-radius: 12px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        box-shadow: var(--shadow-sm);
        transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
    }
    .med-card:hover {
        border-color: var(--primary);
        box-shadow: 0 8px 24px rgba(0,0,0,0.15);
        transform: translateY(-2px);
    }

    .med-img-box {
        width: 100%;
        aspect-ratio: 1;
        background: var(--surface-light);
        position: relative;
        border-bottom: 1px solid var(--glass-border);
    }
    .med-img-box img { width: 100%; height: 100%; object-fit: cover; }
    .med-img-fallback {
        position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
        font-size: 2rem; font-weight: 800; color: var(--text-muted); opacity: 0.4;
    }

    .med-content-box {
        padding: 8px 10px;
        display: flex;
        flex-direction: column;
        gap: 3px;
        flex: 1;
    }
    .med-title {
        font-size: 0.95rem; font-weight: 600; color: var(--text-main); margin: 0;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .med-company {
        font-size: 0.75rem; color: var(--text-muted); margin: 0;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .med-meta-row {
        display: flex; justify-content: space-between; align-items: center; margin-top: 4px;
    }
    .med-price { font-weight: 800; color: var(--primary); font-size: 0.95rem; }
    
    .med-stock-tag {
        font-size: 0.65rem; font-weight: 700; padding: 2px 6px; border-radius: 4px;
        background: rgba(16, 185, 129, 0.12); color: #34d399; border: 1px solid rgba(16,185,129,0.15);
    }
    .med-stock-tag.out {
        background: rgba(239, 68, 68, 0.12); color: #f87171; border-color: rgba(239,68,68,0.15);
    }

    /* Miniature Actions Footer */
    .med-card-footer {
        display: flex; justify-content: space-between; align-items: center;
        margin-top: 6px; padding-top: 8px; border-top: 1px dashed var(--glass-border);
    }
    .med-action-btn-group { display: flex; gap: 6px; }
    .med-mini-btn {
        width: 30px; height: 30px; border-radius: 8px; border: 1px solid var(--glass-border);
        background: var(--surface-light); color: var(--text-muted);
        display: flex; align-items: center; justify-content: center; cursor: pointer;
        transition: all 0.2s ease; font-size: 0.95rem;
    }
    .med-mini-btn:hover { color: var(--primary); background: rgba(59, 130, 246, 0.15); border-color: var(--primary); }
    .med-mini-btn.danger:hover { color: var(--danger); background: rgba(239, 68, 68, 0.15); border-color: var(--danger); }
    .med-mini-btn.chevron.open i { transform: rotate(180deg); }
    .med-mini-btn.chevron i { transition: transform 0.2s ease; }

    /* Collapsible content segment */
    .med-collapsible-desc {
        max-height: 0; overflow: hidden; background: var(--bg-dark);
        transition: max-height 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        font-size: 0.8rem; color: var(--text-muted); line-height: 1.4;
    }
    .med-collapsible-desc.show { max-height: 120px; border-top: 1px solid var(--glass-border); }

    /* Modals CSS adjustments */
    .custom-backdrop {
        display: none; position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
        background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 9999;
        align-items: center; justify-content: center;
    }
    .modal-content-animated {
        background: var(--surface-dark); border: 1px solid var(--glass-border);
        border-radius: 16px; padding: 20px; width: 90%; max-width: 450px;
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
        animation: slideUpFade 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; }
</style>

<div id="toast-container"></div>

<section class="create-medicine-card">
    <h2><i class="ph ph-flask"></i> <%= t.adminMedicines.addNew %></h2>
    <form class="grid-form-compact" id="createMedicineForm">
        
        <div class="floating-field">
            <input type="text" name="name" placeholder=" " required>
            <label><%= t.userRequest.medName %></label>
        </div>
        
        <div class="floating-field">
            <input type="text" name="companyName" placeholder=" " required>
            <label><%= t.adminMedicines.company %></label>
        </div>
        
        <div class="floating-field">
            <input type="number" name="price" step="0.01" placeholder=" " required>
            <label><%= t.common.price %> (؋)</label>
        </div>
        
        <div class="floating-field">
            <input type="number" name="stockQuantity" placeholder=" " required>
            <label><%= t.adminMedicines.availableStock %></label>
        </div>
        
        <div class="file-upload-box">
            <i class="ph ph-image" style="color: var(--primary); font-size: 1.2rem; margin-right: 6px;"></i>
            <span id="file-chosen-text"><%= t.adminMedicines.uploadImage %></span>
            <input type="file" name="imageURL" accept="image/*" onchange="document.getElementById('file-chosen-text').innerText = this.files[0].name"> 
        </div>

        <div class="floating-field field-full-width">
            <textarea name="description" rows="1" placeholder=" " style="resize: none; padding-top: 18px;"></textarea>
            <label><%= t.userRequest.description %></label>
        </div>
        
        <div class="progress-bar-wrapper" id="uploadProgressContainer">
            <div class="progress-bar-fill" id="uploadProgressBar"></div>
        </div>
        
        <button type="submit" class="btn-submit-med" id="submitBtn">
            <i class="ph ph-plus-circle"></i> <%= t.adminMedicines.addNew %>
        </button>
    </form>
</section>

<div class="medicine-dense-grid" id="medicineGrid">
    <% medicines.forEach(med => { %>
        <div class="med-card" id="row-<%= med._id %>">
            
            <div class="med-img-box">
                <% if(med.imageURL) { %>
                    <img src="<%= med.imageURL %>" alt="<%= med.name %>" loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
                    <span class="med-img-fallback" style="display:none;"><%= med.name.charAt(0).toUpperCase() %></span>
                <% } else { %>
                    <span class="med-img-fallback"><%= med.name.charAt(0).toUpperCase() %></span>
                <% } %>
            </div>

            <div class="med-content-box">
                <h4 class="med-title" title="<%= med.name %>"><%= med.name %></h4>
                <p class="med-company" title="<%= med.companyName %>"><%= med.companyName %></p>
                
                <div class="med-meta-row">
                    <span class="med-price">؋<%= med.price.toLocaleString() %></span>
                    <span class="med-stock-tag <%= med.stock == 0 ? 'out' : '' %>">
                        <%= med.stock > 0 ? med.stock + ' ' + (t.adminMedicines.inStock || 'In Stock') : (t.userDashboard.outOfStock || 'Out') %>
                    </span>
                </div>

                <div class="med-card-footer">
                    <button class="med-mini-btn chevron" onclick="toggleCardDesc(this)" title="Toggle Description">
                        <i class="ph ph-caret-down"></i>
                    </button>
                    <div class="med-action-btn-group">
                        <button class="med-mini-btn" onclick="openEditModal('<%= encodeURIComponent(JSON.stringify(med)) %>')" title="Edit product">
                            <i class="ph ph-pencil-simple"></i>
                        </button>
                        <button class="med-mini-btn danger" onclick="openDeleteModal('<%= med._id %>')" title="Delete product">
                            <i class="ph ph-trash" style="stroke-width: 30px;"></i>
                        </button>
                    </div>
                </div>
            </div>

            <div class="med-collapsible-desc">
                <div style="padding: 8px 10px;"><%= med.description || 'No description assigned.' %></div>
            </div>

        </div>
    <% }) %>
</div>

<div class="custom-backdrop" id="editModal">
    <div class="modal-content-animated">
        <h3 style="margin-top:0; font-size: 1.15rem; display: flex; align-items: center; gap: 8px;"><i class="ph ph-pencil-simple" style="color:var(--primary);"></i> Edit Product</h3>
        
        <form id="editMedicineForm" class="grid-form-compact" style="grid-template-columns: 1fr; margin-top: 14px;">
            <input type="hidden" name="id" id="editId">
            
            <div class="floating-field">
                <input type="text" name="name" id="editName" placeholder=" " required>
                <label>Medicine Name</label>
            </div>
            
            <div class="floating-field">
                <input type="text" name="companyName" id="editCompany" placeholder=" " required>
                <label>Company</label>
            </div>
            
            <div class="floating-field">
                <input type="number" name="price" step="0.01" id="editPrice" placeholder=" " required>
                <label>Price (؋)</label>
            </div>
            
            <div class="floating-field">
                <input type="number" name="stockQuantity" id="editStock" placeholder=" " required>
                <label>Stock Quantity</label>
            </div>

            <div class="floating-field">
                <textarea name="description" id="editDesc" rows="2" placeholder=" " style="resize: none; padding-top: 18px;"></textarea>
                <label>Description</label>
            </div>
            
            <div class="modal-actions">
                <button type="button" class="btn-outline" onclick="closeEditModal()">Cancel</button>
                <button type="submit" class="btn-create" style="width: auto; margin:0; padding: 8px 20px;" id="editSubmitBtn">Save Updates</button>
            </div>
        </form>
    </div>
</div>

<div class="custom-backdrop" id="deleteModal">
    <div class="modal-content-animated" style="border-color: rgba(239, 68, 68, 0.3);">
        <h3 style="margin-top:0; font-size: 1.1rem; color: var(--danger); display: flex; align-items: center; gap: 8px;"><i class="ph ph-warning"></i> Remove Item</h3>
        <p style="font-size: 0.9rem; color: var(--text-main); margin-bottom: 20px;">Are you certain you want to delete this medicine product?</p>
        
        <div class="modal-actions">
            <button type="button" class="btn-outline" onclick="closeDeleteModal()">Cancel</button>
            <button type="button" class="btn-danger" id="confirmDeleteBtn">Delete product</button>
        </div>
    </div>
</div>

<script>
    // ----- DESCRIPTIONS COLLAPSIBLE TOGGLE -----
    function toggleCardDesc(btn) {
        const card = btn.closest('.med-card');
        const content = card.querySelector('.med-collapsible-desc');
        btn.classList.toggle('open');
        content.classList.toggle('show');
    }

    // ----- TOAST ALERTS HELPER -----
    function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        if (!container) return alert(message);
        
        const toast = document.createElement('div');
        const icon = type === 'success' ? '<i class="ph ph-check-circle"></i>' : '<i class="ph ph-warning-circle"></i>';
        toast.className = `toast ${type}`;
        toast.innerHTML = `${icon} <span>${message}</span>`;
        container.appendChild(toast);
        
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-20px)';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    // ----- INITIALIZE DELETIONS & EDITS NATIVE LOGIC -----
    let deleteId = null;
    
    function openDeleteModal(id) {
        deleteId = id;
        document.getElementById('deleteModal').style.display = 'flex';
    }
    function closeDeleteModal() {
        document.getElementById('deleteModal').style.display = 'none';
        deleteId = null;
    }

    function openEditModal(encodedJson) {
        const med = JSON.parse(decodeURIComponent(encodedJson));
        document.getElementById('editId').value = med._id;
        document.getElementById('editName').value = med.name;
        document.getElementById('editCompany').value = med.companyName;
        document.getElementById('editPrice').value = med.price;
        document.getElementById('editStock').value = med.stock;
        document.getElementById('editDesc').value = med.description || '';
        
        // Manual trigger floating label activation styles on values load
        document.querySelectorAll('#editMedicineForm .floating-field input, #editMedicineForm .floating-field textarea').forEach(el => {
            el.placeholder = " ";
        });

        document.getElementById('editModal').style.display = 'flex';
    }
    function closeEditModal() {
        document.getElementById('editModal').style.display = 'none';
    }

    // Close modals on generic overlay shadow click
    window.onclick = function(e) {
        if (e.target === document.getElementById('editModal')) closeEditModal();
        if (e.target === document.getElementById('deleteModal')) closeDeleteModal();
    }

    // --- ASYNC FORM CREATION WITH NATIVE XHR TRACKING ---
    document.getElementById('createMedicineForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        const form = this;
        const formData = new FormData(form);
        const submitBtn = document.getElementById('submitBtn');
        const progressContainer = document.getElementById('uploadProgressContainer');
        const progressBar = document.getElementById('uploadProgressBar');
        
        submitBtn.disabled = true;
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i class="ph ph-spinner ph-spin"></i> processing...';
        
        progressContainer.style.display = 'block';
        progressBar.style.width = '0%';

        const xhr = new XMLHttpRequest();
        xhr.open('POST', '/admin/medicines', true);

        xhr.upload.addEventListener('progress', function(e) {
            if (e.lengthComputable) {
                const percentComplete = (e.loaded / e.total) * 100;
                progressBar.style.width = percentComplete + '%';
            }
        });

        xhr.addEventListener('load', function() {
            if (xhr.status === 200 || xhr.status === 201) {
                showToast('Medicine created successfully!', 'success');
                setTimeout(() => location.reload(), 800);
            } else {
                let errorMsg = 'Error saving product details';
                try {
                    const resData = JSON.parse(xhr.responseText);
                    errorMsg = resData.message || errorMsg;
                } catch(err){}
                showToast(errorMsg, 'error');
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                progressContainer.style.display = 'none';
            }
        });

        xhr.addEventListener('error', function() {
            showToast('Network file upload execution failed', 'error');
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
            progressContainer.style.display = 'none';
        });

        xhr.send(formData);
    });

    // --- ASYNC PUT SUBMISSION MODAL FORM ---
    document.getElementById('editMedicineForm').addEventListener('submit', async function(e) {
        e.preventDefault();
        const submitBtn = document.getElementById('editSubmitBtn');
        submitBtn.disabled = true;
        const originalText = submitBtn.innerText;
        submitBtn.innerText = '...';

        const id = document.getElementById('editId').value;
        const payload = {
            name: document.getElementById('editName').value,
            companyName: document.getElementById('editCompany').value,
            price: document.getElementById('editPrice').value,
            stockQuantity: document.getElementById('editStock').value,
            description: document.getElementById('editDesc').value
        };

        try {
            const res = await fetch(`/admin/medicines/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (res.ok) {
                showToast('Medicine updated successfully!', 'success');
                setTimeout(() => location.reload(), 800);
            } else {
                const data = await res.json();
                showToast(data.message || 'Error updating item attributes', 'error');
                submitBtn.disabled = false;
                submitBtn.innerText = originalText;
            }
        } catch (err) {
            showToast('Network pipeline error occurred', 'error');
            submitBtn.disabled = false;
            submitBtn.innerText = originalText;
        }
    });

    // --- DELETE ROUTE HANDLER EXECUTIONS ---
    document.getElementById('confirmDeleteBtn').addEventListener('click', async function() {
        if (!deleteId) return;
        this.disabled = true;
        this.innerText = '...';
        
        try {
            const res = await fetch(`/admin/medicines/${deleteId}`, { method: 'DELETE' });
            if (res.ok) {
                const targetCard = document.getElementById(`row-${deleteId}`);
                if (targetCard) targetCard.remove();
                showToast('Medicine target entity deleted', 'success');
            } else {
                showToast('Failed to fulfill product deletion', 'error');
            }
        } catch (err) {
            showToast('Network verification error', 'error');
        } finally {
            this.disabled = false;
            this.innerText = '<%= t.common.delete || "Delete" %>';
            closeDeleteModal();
        }
    });
</script>

<%- include('partials/admin-footer', { page: 'medicines' }) %>