<%- include('partials/admin-header', { title: t.adminMedicines.title, page: 'medicines' }) %>

<section class="card mb-2">
    <div class="card-header">
        <h2><%= t.adminMedicines.addNew %></h2>
    </div>
    <form class="grid-form" id="createMedicineForm">
        <div class="form-group">
            <label><%= t.userRequest.medName %></label>
            <input type="text" name="name" placeholder="e.g. Aspirin" required>
        </div>
        <div class="form-group">
            <label><%= t.adminMedicines.company %></label>
            <input type="text" name="companyName" placeholder="e.g. Bayer" required>
        </div>
        <div class="form-group">
            <label><%= t.common.price %> (؋)</label>
            <input type="number" name="price" step="0.01" placeholder="0.00" required>
        </div>
        <div class="form-group">
            <label><%= t.adminMedicines.availableStock %></label>
            <input type="number" name="stockQuantity" placeholder="06" required>
        </div>
        <div class="form-group">
            <label><%= t.adminMedicines.uploadImage %></label>
            <input type="file" name="imageURL" accept="image/*"> 
        </div>
        
        <div id="uploadProgressContainer" style="display: none; margin-bottom: 15px;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                <span style="font-size: 0.85rem; color: var(--text-muted);"><%= t.adminMedicines.uploading %></span>
                <span id="progressText" style="font-size: 0.85rem; font-weight: bold;">0%</span>
            </div>
            <div style="width: 100%; height: 6px; background: var(--surface-hover); border-radius: 3px; overflow: hidden;">
                <div id="progressBar" style="width: 0%; height: 100%; background: var(--primary); transition: width 0.2s;"></div>
            </div>
        </div>
        
        <div class="form-group full-width">
            <button type="submit" class="btn-primary addBtn"><%= t.adminMedicines.addBtn %></button>
        </div>
    </form>
</section>

<section style="margin-top: 2rem;">
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 1rem;">
        <% medicines.forEach(med => { %>
            <div class="product-card" id="row-<%= med._id %>" style="cursor: pointer; display: flex; flex-direction: column;" onclick="document.getElementById('view-btn-<%= med._id %>').click()">
                <div class="product-img" style="height: 130px;">
                    <img src="<%= med.imageURL %>" alt="<%= med.name %>" style="width: 100%; height: 100%; object-fit: cover;">
                </div>
                <div style="padding: 10px 12px; display: flex; justify-content: space-between; align-items: center; flex: 1;">
                    <span style="font-size: 0.9rem; font-weight: 600; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 70%;">
                        <%= med.companyName %>
                    </span>
                    <button type="button" id="view-btn-<%= med._id %>" class="view-btn" style="background: rgba(59, 130, 246, 0.1); border: none; color: var(--primary); cursor: pointer; font-size: 1.2rem; width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;" 
                            data-id="<%= med._id %>"
                            data-name="<%= med.name %>"
                            data-company="<%= med.companyName %>"
                            data-price="<%= med.price %>"
                            data-stock="<%= med.stockQuantity %>"
                            data-image="<%= med.imageURL %>"
                            onclick="event.stopPropagation(); openDetailsModal(this)">
                        <i class="ph ph-eye"></i>
                    </button>
                </div>
            </div>
        <% }) %>
    </div>
</section>

<div id="toast-container"></div>

<div id="detailsModal" class="modal-backdrop" style="display: none;">
    <div class="modal-content" style="display: block; opacity: 1; max-width: 420px; padding: 1.5rem;">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
            <h3 style="margin: 0; font-size: 1.4rem; color: var(--text-main);" id="detail-name"></h3>
            <button type="button" onclick="closeDetailsModal()" style="background: transparent; border: none; color: var(--text-muted); font-size: 1.5rem; cursor: pointer; line-height: 1;">&times;</button>
        </div>
        
        <img id="detail-image" src="" alt="Medicine" style="width: 100%; height: 220px; object-fit: cover; border-radius: 12px; margin-bottom: 1.5rem; border: 1px solid var(--glass-border);">
        
        <div style="background: var(--surface-light); padding: 1rem; border-radius: 12px; margin-bottom: 1.5rem;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 10px; border-bottom: 1px solid var(--glass-border); padding-bottom: 10px;">
                <span class="text-muted"><%= t.adminMedicines.company || 'Company' %></span>
                <strong id="detail-company" style="color: var(--text-main);"></strong>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 10px; border-bottom: 1px solid var(--glass-border); padding-bottom: 10px;">
                <span class="text-muted"><%= t.common.price || 'Price' %></span>
                <strong style="color: var(--text-main);">$<span id="detail-price"></span></strong>
            </div>
            <div style="display: flex; justify-content: space-between;">
                <span class="text-muted"><%= t.common.stock || 'Stock' %></span>
                <span id="detail-stock-container"></span>
            </div>
        </div>

        <div style="display: flex; gap: 10px;">
            <button type="button" class="btn-icon" style="flex: 1; border-radius: 8px; color: var(--primary); border-color: var(--primary); gap: 6px; font-weight: bold;" onclick="triggerEditFromDetails()">
                <i class="ph ph-pencil-simple" style="font-size: 1.2rem;"></i> <%= t.common.edit || 'Edit' %>
            </button>
            <button type="button" class="btn-icon" style="flex: 1; border-radius: 8px; color: var(--danger); border-color: var(--danger); gap: 6px; font-weight: bold;" onclick="triggerDeleteFromDetails()">
                <i class="ph ph-trash" style="font-size: 1.2rem;"></i> <%= t.common.delete || 'Delete' %>
            </button>
        </div>
    </div>
</div>

<div id="editModal" class="modal-backdrop" style="display: none;">
    <div class="modal-content" style="display: block; opacity: 1; max-width: 500px; padding: 2rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h3 style="margin: 0;"><%= t.common.edit || 'Edit Medicine' %></h3>
            <button type="button" onclick="closeEditModal()" style="background: transparent; border: none; color: var(--text-muted); font-size: 1.5rem; cursor: pointer;">&times;</button>
        </div>
        <form id="editMedicineForm">
            <input type="hidden" id="editId" name="id">
            <div class="form-group">
                <label><%= t.userRequest.medName || 'Medicine Name' %></label>
                <input type="text" id="editName" name="name" required>
            </div>
            <div class="form-group">
                <label><%= t.adminMedicines.company || 'Company' %></label>
                <input type="text" id="editCompany" name="companyName" required>
            </div>
            <div class="form-group">
                <label><%= t.common.price || 'Price' %> (؋)</label>
                <input type="number" id="editPrice" name="price" step="0.01" required>
            </div>
            <div class="form-group">
                <label><%= t.adminMedicines.availableStock || 'Available Stock' %></label>
                <input type="number" id="editStock" name="stockQuantity" required>
            </div>
            <div class="form-group">
                <label><%= t.adminMedicines.uploadImage || 'Upload New Image (Optional)' %></label>
                <input type="file" name="imageURL" accept="image/*">
            </div>
            <div class="modal-actions">
                <button type="submit" class="btn-primary" style="width: 100%;"><%= t.common.save || 'Save Changes' %></button>
            </div>
        </form>
    </div>
</div>

<div id="deleteModal" class="modal-backdrop" style="display: none;">
    <div class="modal-content confirmation-box" style="display: block; opacity: 1;">
        <div class="icon-box danger large" style="margin: 0 auto 15px;">
            <i class="ph ph-trash"></i>
        </div>
        <h3 style="text-align: center;"><%= t.common.delete %>?</h3>
        <p style="text-align: center; color: var(--text-muted);"><%= t.adminMedicines.deleteConfirmMessage || "Are you sure you want to delete this medicine?" %></p>
        <div class="modal-actions" style="display: flex; gap: 10px; margin-top: 20px;">
            <button class="btn-cancel" onclick="closeDeleteModal()" style="flex: 1;"><%= t.common.cancel %></button>
            <button class="btn-delete" id="confirmDeleteBtn" style="flex: 1;"><%= t.common.delete %></button>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const deleteModal = document.getElementById('deleteModal');
        const editModal = document.getElementById('editModal');
        const detailsModal = document.getElementById('detailsModal');
        const toastContainer = document.getElementById('toast-container');
    
        if(deleteModal) document.body.appendChild(deleteModal);
        if(editModal) document.body.appendChild(editModal);
        if(detailsModal) document.body.appendChild(detailsModal);
        if(toastContainer) document.body.appendChild(toastContainer);
    });

    function showToast(message, type = 'success') {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        const icon = type === 'success' ? '<i class="ph ph-check-circle"></i>' : '<i class="ph ph-warning-circle"></i>';
        toast.className = `toast ${type}`; 
        toast.innerHTML = `${icon} <span>${message}</span>`;
        container.appendChild(toast);

        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateY(-20px)';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }

    // --- CREATE MEDICINE ---
    const createForm = document.getElementById('createMedicineForm');
    createForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const btn = createForm.querySelector('.addBtn');
        const originalText = btn.innerText;
        const progressBar = document.getElementById('progressBar');
        const progressContainer = document.getElementById('uploadProgressContainer');
        const progressText = document.getElementById('progressText');

        const formData = new FormData(createForm);
        const isPublished = createForm.querySelector('input[name="isPublished"]').checked;
        formData.set('isPublished', isPublished); 

        btn.disabled = true;
        btn.innerText = 'Uploading...';
        if(progressContainer) progressContainer.style.display = 'block';

        try {
            let progress = 0;
            const interval = setInterval(() => {
                progress += Math.random() * 10;
                if(progress > 90) progress = 90;
                if(progressBar) progressBar.style.width = `${progress}%`;
                if(progressText) progressText.innerText = `${Math.round(progress)}%`;
            }, 200);

            const res = await fetch('/admin/medicines', {
                method: 'POST',
                body: formData
            });

            clearInterval(interval);
            if(progressBar) progressBar.style.width = '100%';
            if(progressText) progressText.innerText = '100%';

            const data = await res.json();
            if (res.ok) {
                showToast('Medicine added successfully!', 'success');
                createForm.reset();
                setTimeout(() => location.reload(), 1000); 
            } else {
                showToast(data.message || 'Error creating medicine', 'error');
            }
        } catch (err) {
            showToast('Network error occurred', 'error');
        } finally {
            btn.disabled = false;
            btn.innerText = originalText;
            setTimeout(() => {
                if(progressContainer) progressContainer.style.display = 'none';
            }, 2000);
        }
    });

    // --- DETAILS MODAL LOGIC (FIXED) ---
    let currentDetailData = null;

    function openDetailsModal(btn) {
        currentDetailData = btn.dataset;
        
        document.getElementById('detail-name').innerText = currentDetailData.name;
        document.getElementById('detail-company').innerText = currentDetailData.company;
        document.getElementById('detail-price').innerText = parseFloat(currentDetailData.price || 0).toFixed(2);
        document.getElementById('detail-image').src = currentDetailData.image;
        
        const stock = parseInt(currentDetailData.stock || 0);
        const stockContainer = document.getElementById('detail-stock-container');
        if(stock >= 1) {
            stockContainer.innerHTML = `<span class="text-success" style="background: rgba(16, 185, 129, 0.1); padding: 4px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 600;">${stock} <%= t.adminMedicines.inStock || 'In Stock' %></span>`;
        } else {
            stockContainer.innerHTML = `<span class="text-danger" style="background: rgba(239, 68, 68, 0.1); padding: 4px 10px; border-radius: 12px; font-size: 0.8rem; font-weight: 600;"><%= t.adminMedicines.outOfStock || 'Out of Stock' %></span>`;
        }

        // Direct style manipulation bypasses CSS conflicts
        document.getElementById('detailsModal').style.display = 'block';
    }

    function closeDetailsModal() {
        document.getElementById('detailsModal').style.display = 'none';
        currentDetailData = null;
    }

    // --- TRIGGER EDIT / DELETE FROM DETAILS ---
    let deleteId = null;

    function triggerEditFromDetails() {
        if(!currentDetailData) return;
        
        document.getElementById('editId').value = currentDetailData.id;
        document.getElementById('editName').value = currentDetailData.name;
        document.getElementById('editCompany').value = currentDetailData.company;
        document.getElementById('editPrice').value = currentDetailData.price;
        document.getElementById('editStock').value = currentDetailData.stock;
        
        closeDetailsModal();
        document.getElementById('editModal').style.display = 'block';
    }

    function triggerDeleteFromDetails() {
        if(!currentDetailData) return;
        
        deleteId = currentDetailData.id;
        closeDetailsModal();
        document.getElementById('deleteModal').style.display = 'block';
    }

    // --- MODAL CLOSE HELPERS ---
    function closeEditModal() {
        document.getElementById('editModal').style.display = 'none';
        document.getElementById('editMedicineForm').reset();
    }

    function closeDeleteModal() {
        deleteId = null;
        document.getElementById('deleteModal').style.display = 'none';
    }

    // --- EDIT SUBMISSION ---
    const editForm = document.getElementById('editMedicineForm');
    editForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = editForm.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerText;
        
        submitBtn.disabled = true;
        submitBtn.innerText = 'Saving...';

        const id = document.getElementById('editId').value;
        const formData = new FormData(editForm);

        try {
            const res = await fetch(`/admin/medicines/${id}`, {
                method: 'PUT',
                body: formData
            });

            if (res.ok) {
                showToast('Medicine updated successfully!', 'success');
                setTimeout(() => location.reload(), 1000);
            } else {
                const data = await res.json();
                showToast(data.message || 'Error updating medicine', 'error');
                submitBtn.disabled = false;
                submitBtn.innerText = originalText;
            }
        } catch (err) {
            showToast('Network error occurred', 'error');
            submitBtn.disabled = false;
            submitBtn.innerText = originalText;
        }
    });

    // --- DELETE SUBMISSION ---
    document.getElementById('confirmDeleteBtn').addEventListener('click', async function() {
        if (!deleteId) return;
        
        this.innerText = '...';
        try {
            const res = await fetch(`/admin/medicines/${deleteId}`, { method: 'DELETE' });
            if (res.ok) {
                const row = document.getElementById(`row-${deleteId}`);
                if (row) row.remove();
                showToast('Medicine deleted successfully', 'success');
            } else {
                showToast('Failed to delete', 'error');
            }
        } catch (err) {
            showToast('Network Error', 'error');
        } finally {
            this.innerText = '<%= t.common.delete || "Delete" %>';
            closeDeleteModal();
        }
    });
</script>

<%- include('partials/admin-footer', { page: 'medicines' }) %>